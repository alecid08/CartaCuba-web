---
import BaseLayout from '../layouts/BaseLayout.astro';
import TourCard from '../components/TourCard.astro';
---

<BaseLayout title="Destino Camagüey | CartaCuba" activePage="destino">
  <div class="grain-texture fixed inset-0 z-0 pointer-events-none opacity-40"></div>

  <!-- Hero Section -->
  <section class="relative h-[60vh] min-h-[450px] overflow-hidden flex items-center justify-center text-center">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDzJbCzSWWEURx_HC4cIVlOLmhNAk8vVuS3EpqqDykV2YH97cHzFqRfos930Yr4_5fTHI_LI6rQ4tckXZzkwQmmOgmQqIanBjMKTc6zLyH3F8Q4cyyReHWS5piDwd9rk5FAzX3zJ4I5daeFWCsNd9QmzKP9YRpb3CbOKFRML2Q7CoVXJAWRVH77YJ40p4ot4IDY0_sCUuL6cRIM9qwVbWMm2nTd8DiPTIKshHDufuThKxItDlJkmS4PV4IJ2VfCa4PEQ-Wti4XHY6w');">
      <div class="absolute inset-0 bg-black/50"></div>
    </div>
    <div class="relative z-10 px-margin-mobile md:px-margin-desktop max-w-4xl mx-auto space-y-4 text-white">
      <span class="inline-block bg-primary/30 border border-primary-fixed/40 text-primary-fixed px-4 py-1.5 rounded-full font-label-md text-sm uppercase tracking-wider">
        Explora la Región Agramontina
      </span>
      <h1 class="font-display-lg text-display-lg-mobile md:text-5xl lg:text-6xl font-bold leading-tight drop-shadow-md">
        Camagüey: Barro, Leyendas y <span class="text-primary-fixed italic font-normal">Naturaleza Viva</span>
      </h1>
      <p class="font-body-lg text-white/90 max-w-2xl mx-auto text-sm md:text-base">
        Una inmersión profunda a través del laberinto colonial más grande del Caribe, las tradiciones alfareras centenarias y el santuario de aves de la Sierra del Chorrillo.
      </p>
    </div>
  </section>

  <!-- Interactive Section Tabs -->
  <section class="py-6 bg-surface-container border-b border-outline-variant/30 sticky top-20 z-40 shadow-sm">
    <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
      <div class="flex justify-center gap-2 md:gap-6">
        <button 
          class="tab-btn active px-4 py-2.5 rounded-full font-label-md text-sm transition-all flex items-center gap-2 bg-primary text-white"
          data-tab="naturaleza"
        >
          <span class="material-symbols-outlined text-lg">eco</span>
          <span>Naturaleza</span>
        </button>
        <button 
          class="tab-btn px-4 py-2.5 rounded-full font-label-md text-sm transition-all flex items-center gap-2 text-on-surface-variant hover:bg-surface-container-highest"
          data-tab="patrimonio"
        >
          <span class="material-symbols-outlined text-lg">architecture</span>
          <span>Patrimonio e Historia</span>
        </button>
        <button 
          class="tab-btn px-4 py-2.5 rounded-full font-label-md text-sm transition-all flex items-center gap-2 text-on-surface-variant hover:bg-surface-container-highest"
          data-tab="cultura"
        >
          <span class="material-symbols-outlined text-lg">palette</span>
          <span>Tradición y Cultura</span>
        </button>
      </div>
    </div>
  </section>

  <main class="relative z-10 bg-background min-h-screen">
    
    <!-- ================= NATURALEZA TAB ================= -->
    <div id="tab-naturaleza" class="tab-content block">
      <!-- Species Spotlight: Cartacuba -->
      <section class="py-20 bg-surface-container-low relative">
        <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
          <div class="grid md:grid-cols-2 gap-16 items-center">
            <div class="relative">
              <div class="leaf-corner overflow-hidden aspect-[4/5] shadow-xl">
                <img class="w-full h-full object-cover" alt="Cartacuba bird (Todus multicolor)" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCQwIULpWJ17ul5O1lHNna3YCyoTqOcSpFNP6hAEr2R3LJZQh0wTv2e2W4dELlbm4L6cwIXQPJ70029GuW8QIgG6u4lSDvDIGN5k1yulQv01LD1Zq7j_yCmbrlTJwNXI44iZ7VJMm_K50md6EjmwJ8fqZUj2C8iSXe6ZCBZch1Ao9EfptJ5TeWuhkf1SvHss0q35zRjb5Sh6omjUBP-JRGL2t3JW91GHlBx4pTA3Kk32k3e_PhvumMRJ9rZH-BeAQcW5HLf8VrJKRXQCg">
              </div>
              <div class="absolute -bottom-8 -right-8 bg-primary-fixed p-8 leaf-corner shadow-lg max-w-[200px]">
                <span class="text-on-primary-fixed font-headline-sm block mb-2 font-semibold">Todus multicolor</span>
                <p class="text-on-primary-fixed/90 text-[12px] uppercase tracking-widest font-bold">Joya Endémica</p>
              </div>
            </div>
            <div>
              <span class="text-primary font-label-md uppercase tracking-wider block mb-2">Fauna Emblemática</span>
              <h2 class="font-headline-md text-headline-md text-on-surface mb-6 font-semibold">El Cartacuba: Un Espectro Vivo</h2>
              <p class="font-body-lg text-body-lg text-on-surface-variant mb-6">
                El homónimo de nuestra marca, el <em>Cartacuba</em> (Todus multicolor), es una diminuta maravilla de la biosfera. Midiendo apenas 11 centímetros, esta criatura iridiscente encarna la vibrante resiliencia de los bosques de Camagüey.
              </p>
              <ul class="space-y-4 mb-8">
                <li class="flex items-start gap-4">
                  <span class="material-symbols-outlined text-primary p-2 bg-primary/10 rounded-lg">nest_multi_room</span>
                  <div>
                    <strong class="text-on-surface block font-bold">Hábitat Único</strong>
                    <span class="text-body-md text-on-surface-variant">Anida en madrigueras de tierra excavadas en bancos de arcilla verticales a lo largo de senderos sombreados.</span>
                  </div>
                </li>
                <li class="flex items-start gap-4">
                  <span class="material-symbols-outlined text-primary p-2 bg-primary/10 rounded-lg">palette</span>
                  <div>
                    <strong class="text-on-surface block font-bold">El Rojo "Cartacuba"</strong>
                    <span class="text-body-md text-on-surface-variant">Famoso por su distintiva garganta roja brillante, pecho rosado y su plumaje verde metálico.</span>
                  </div>
                </li>
              </ul>
              <div class="p-6 bg-surface-container-highest rounded-xl border-l-4 border-primary">
                <p class="italic text-on-surface font-headline-sm text-lg">"En el silencio de la Sierra del Chorrillo, el chasquido del pico de un Cartacuba es el ritmo del bosque."</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Biodiversity Bento Grid -->
      <section class="py-20 bg-background">
        <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
          <div class="text-center mb-16">
            <span class="text-primary font-label-md uppercase tracking-wider block mb-2">Ecosistema Protegido</span>
            <h2 class="font-headline-md text-headline-md text-on-surface mb-4 font-semibold">Portafolio de Biodiversidad</h2>
            <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto">Descubre la intrincada red de vida que hace de Camagüey un centro de endemismo reconocido mundialmente.</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-4 md:grid-rows-2 gap-6 h-auto md:h-[700px]">
            <!-- Large Card: Flora -->
            <TourCard
              type="experience"
              cardClass="md:col-span-2 md:row-span-2 relative group overflow-hidden leaf-corner bg-surface-container-low shadow-sm hover:shadow-xl transition-all border border-outline-variant/30 h-full"
              image="https://lh3.googleusercontent.com/aida-public/AB6AXuAb4YNF0ee5dMvmvsRiZkC9RT7hrxVpwHxM-dUSqWlJUx4I9bG6MOYhN-41-wBlI8wVufM4b-_uHekwl8l4KPVhl8MMFQ_LYP_qCENsL9FGX7FEmQGAQf9VP7ghpOAxQ0x_nwZCNnTooObAn9kXmnPem2mrMplNIAPPgSc0D579G3o9yr66bsEjsd3n_cFSSWJM7EtjckLzuNyyexoAgVa4DJcfXbfHTY-jC9zmxzGTmPJqwjTrJ-v4-GokMAxCNDcZbrH3UiIB6cE"
              badgeText="Flora"
              badgeClass="bg-primary"
              title="Bosques de la Sierra de Cubitas"
              description="Hogar de más de 300 especies de helechos y la prehistórica Microcycas calocoma."
            />

            <!-- Medium Card: Reptiles -->
            <div class="md:col-span-2 relative group overflow-hidden rounded-xl bg-surface-container shadow-sm border border-outline-variant/30">
              <div class="grid md:grid-cols-2 h-full">
                <div class="p-8 flex flex-col justify-center">
                  <span class="text-primary font-label-md mb-2">Reptiles Endémicos</span>
                  <h3 class="font-headline-sm text-on-surface mb-3 font-semibold">Majá de Santa María</h3>
                  <p class="text-body-md text-on-surface-variant mb-4">Un majestuoso depredador de las cuevas de piedra caliza, esencial para el equilibrio del ecosistema.</p>
                </div>
                <div class="relative overflow-hidden min-h-[200px]">
                  <img class="w-full h-full object-cover group-hover:scale-105 transition-transform" alt="Exotic reptile" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCtWux-LkZsDIbemoZp4_eDA2UwVG4nQ5pklxwmaMA-TYUQdHTEUAAA1ZkHsEDQuBDVBJFLxwQs-8GkVTP_ha5TNlvwA5mQcu9UN64FHGpGSRj3gN5LhzCErUM8p905C8ZVU99rdbtIsRS9p6A2ZfNHeWl6B8pFHzDqbUcIyRJCbsgFoSljMgVN5ih2_SX78SJXmyiQ9nUmFGOk7kXSW9gOdefbkF84KLt8FBd4BpDNZ0SRxL5lDwqHYzzK9KpULbf12Ze9W4MYZ8w">
                </div>
              </div>
            </div>
            
            <!-- Small Card: Conservation -->
            <div class="relative group overflow-hidden rounded-xl bg-primary-container p-8 flex flex-col justify-between text-white">
              <span class="material-symbols-outlined text-on-primary-container text-4xl" style="font-variation-settings: 'FILL' 1;">landscape</span>
              <div>
                <h3 class="font-headline-sm mb-2 font-semibold">Reserva Ecológica</h3>
                <p class="text-white/80 text-label-md">Programas de protección Limones-Tuabaquey para la fauna local.</p>
              </div>
            </div>
            
            <!-- Small Card: Maps -->
            <div class="relative group overflow-hidden rounded-xl border border-outline-variant/30 bg-surface-container-highest">
              <img class="absolute inset-0 w-full h-full object-cover opacity-50 grayscale hover:grayscale-0 transition-all duration-500" alt="Topographical map representation" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBBPNBA2TFHPHX6amqhj2UD2wCixcHjQSeM-Qx5UvtZOpZaUh5fHckrg8wi3Kv2RPmQUGs2EpETCN1ldsQczkkDVNQxVTovoNLrnDjOURqmCGihB-imQRp5VHxnVgeV5OlfNGj3rvzRMIfbRK2hLR2Y76mWRMAK_F1dyeksEXZ_uS6JofHRYdojHeY7xlsviHOjmizxTH7_AHxrHTtf1YZgPWiDSKROgmgG1cLpbIEjowBVCSDbw8i97blfxypfY7Wb6OOcAMGf36s">
              <div class="absolute inset-0 flex flex-col items-center justify-center p-6 text-center">
                <span class="material-symbols-outlined text-primary mb-2 text-3xl">map</span>
                <h3 class="font-label-md text-on-surface font-semibold">Senderos de Observación</h3>
                <p class="text-[12px] text-on-surface-variant mt-1">Guía SIG Interactiva</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Local Flora Grid -->
      <section class="py-20 bg-surface-container-high">
        <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
          <div class="max-w-xl mb-12">
            <span class="text-primary font-label-md uppercase tracking-wider block mb-2">Botánica Nativa</span>
            <h2 class="font-headline-md text-headline-md text-on-surface mb-4 font-semibold">Maravillas Botánicas</h2>
            <p class="font-body-lg text-body-lg text-on-surface-variant">La flora de Camagüey es un testimonio de resiliencia, desde los cactus secos de la costa hasta las exuberantes orquídeas de las montañas.</p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-gutter">
            <!-- Flora Item 1 -->
            <div class="group">
              <div class="aspect-square rounded-2xl overflow-hidden mb-4 shadow-sm group-hover:shadow-md transition-shadow">
                <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt="Wild Orchid" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDTe9B-JxqZ5szupHDRwc5neO0AKDCxeePxR3izli7HwDtI5beVViJrZEhrmNBo9rLfhfikRO5L25Nz4Ya-QemDffoxjgPD7ZxZbRoVxjyJq3LHhLz2fRAC6KvUvP66yPKS4OR0QqgX-_NZCYniCe1vM8WqtjyqQVv27iaTrHc90FOH05JSFjKp3QxH8_tNq_SOGVzLbM8Wt0kOQPPL_j1kb8cgTp4-kcuM0HynDqFhKWm55JzfqQUMDTJ5ekaaOTnNjOVcClxVBMw">
              </div>
              <h4 class="font-headline-sm text-on-surface font-semibold">Orquídea Silvestre</h4>
              <p class="text-label-md text-primary uppercase tracking-wider mt-1">Orchidaceae</p>
            </div>
            <!-- Flora Item 2 -->
            <div class="group">
              <div class="aspect-square rounded-2xl overflow-hidden mb-4 shadow-sm group-hover:shadow-md transition-shadow">
                <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt="Coral Shrub" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCXb3g3-vDuDx-GJe0ZkIOPJ0QQdfGNJLAEwYoTcKfysmwUuKhL-v1fn5QwjsyhIas4Tb5jvCaLKsGrhL5ZeNiZ9bIXjSf2_PwQJ9FctJFfhSHfNH6qLTWIorcHB2rjcu3cMUg0CIpOAhwopcLL8ZD0WhyY4ECSxM4S3XIeKiPqs7tF-fOs95G2VJgOeDY7Avq9dwW2GGoiKEiRlWPBGZiTeH0nWDJXWfjxLJS3V9jRQXuVTo5LrG7xrc71Aoz__kntjy4UHLGiTE0">
              </div>
              <h4 class="font-headline-sm text-on-surface font-semibold">Palo de Coral</h4>
              <p class="text-label-md text-primary uppercase tracking-wider mt-1">Hamelia patens</p>
            </div>
            <!-- Flora Item 3 -->
            <div class="group">
              <div class="aspect-square rounded-2xl overflow-hidden mb-4 shadow-sm group-hover:shadow-md transition-shadow">
                <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt="Yarey Palm" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCTYekWgiJg7mjash0-EsDEHFVkz1vF6vcLYV7cyTMJ_TbNCZ0IWBIdike0XnolMCk12c7MGJQq8XhL1EVD0dQSPPdbXmkHi05SYQAXMrl24PU7k-NuITvj36bbwfwwKRE6yTawSliJHwvtuyENpOz6_tWK0CxCaw5jbbApo5nTPEnEEMTO8opD5YWlNynq95nXhasbYxQO8ecGFQHsr_9QAyjmcsYbFlkW0F_AjOg6B_VW8K_T8Yw0gkzlrKP4WwSm8nZdHBhkQjM">
              </div>
              <h4 class="font-headline-sm text-on-surface font-semibold">Palma Yarey</h4>
              <p class="text-label-md text-primary uppercase tracking-wider mt-1">Coccothrinax</p>
            </div>
            <!-- Flora Item 4 -->
            <div class="group">
              <div class="aspect-square rounded-2xl overflow-hidden mb-4 shadow-sm group-hover:shadow-md transition-shadow">
                <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt="Tree Fern" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDUw__XYkIP58d9K9uc_OnugN6K_rJGts7KrDmPaxXq-llydk_d9bR-H7JWOKDCsk6gXs9z3qGg-nO_jrunH-mes9g71-13XPkLUwmNHZ_E1_PPrFjy4m5HOyBSkxndbj5v4wVFUS2lyFN26BDhuQzvb1TFZ0VX37doJpIT4_f1dt--WX3fIgSBaejy_FXRDzYNUez8y0XaCJn01QYlo8L-hW72eI7VzzL4P_O4xq47v9ENAqJVh6BuPxPT_azfiNUvXFNZ2hU4l5Y">
              </div>
              <h4 class="font-headline-sm text-on-surface font-semibold">Helecho Arborescente</h4>
              <p class="text-label-md text-primary uppercase tracking-wider mt-1">Cyatheales</p>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- ================= PATRIMONIO TAB ================= -->
    <div id="tab-patrimonio" class="tab-content hidden">
      <!-- Mapping & Winding City -->
      <section class="py-20 bg-surface-container-low">
        <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter items-start">
            <!-- Sidebar: Landmarks -->
            <div class="lg:col-span-5 space-y-6">
              <span class="text-primary font-label-md uppercase tracking-wider block">Leyenda de Piedra y Laberintos</span>
              <h2 class="font-headline-md text-headline-md text-on-surface font-semibold">La Ciudad Laberinto</h2>
              <p class="font-body-md text-on-surface-variant">
                A diferencia de cualquier otra ciudad colonial española, el centro histórico de Camagüey fue trazado como un laberinto defensivo de calles rotas e irregulares y callejones ciegos, concebidos para romper el avance de piratas invasores como Henry Morgan. Hoy en día es Patrimonio de la Humanidad por la UNESCO.
              </p>
              
              <!-- Landmark Card 1 -->
              <div class="group bg-surface-container-lowest p-6 rounded-xl border border-outline-variant/30 hover:border-primary transition-all cursor-pointer">
                <div class="flex items-start gap-4">
                  <div class="bg-primary-container text-white w-10 h-10 rounded-full flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined">church</span>
                  </div>
                  <div>
                    <h3 class="font-headline-sm text-lg text-on-surface mb-2 font-semibold">San Juan de Dios</h3>
                    <p class="font-body-md text-sm text-on-surface-variant">La plaza colonial más preservada de Cuba. Un conjunto intacto del siglo XVIII compuesto por iglesia, hospital y casonas.</p>
                  </div>
                </div>
              </div>
              <!-- Landmark Card 2 -->
              <div class="group bg-surface-container-lowest p-6 rounded-xl border border-outline-variant/30 hover:border-primary transition-all cursor-pointer">
                <div class="flex items-start gap-4">
                  <div class="bg-primary text-white w-10 h-10 rounded-full flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined">park</span>
                  </div>
                  <div>
                    <h3 class="font-headline-sm text-lg text-on-surface mb-2 font-semibold">Plaza del Carmen</h3>
                    <p class="font-body-md text-sm text-on-surface-variant">Plaza empedrada célebre por sus estatuas de bronce a tamaño real, que inmortalizan personajes costumbristas.</p>
                  </div>
                </div>
              </div>
              <!-- Landmark Card 3 -->
              <div class="group bg-surface-container-lowest p-6 rounded-xl border border-outline-variant/30 hover:border-primary transition-all cursor-pointer">
                <div class="flex items-start gap-4">
                  <div class="bg-tertiary-container text-white w-10 h-10 rounded-full flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined">route</span>
                  </div>
                  <div>
                    <h3 class="font-headline-sm text-lg text-on-surface mb-2 font-semibold">Callejones de Leyenda</h3>
                    <p class="font-body-md text-sm text-on-surface-variant">Callejones sumamente estrechos como el callejón de Fundición o el del Silencio, repletos de misterios locales.</p>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Map Interface -->
            <div class="lg:col-span-7 lg:sticky lg:top-36 mt-8 lg:mt-0">
              <div class="relative rounded-3xl overflow-hidden shadow-2xl border-4 border-surface-container-highest h-[550px]">
                <img alt="Map of Camagüey historic center" class="w-full h-full object-cover grayscale opacity-30" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCDtK47MuTH0yyDrxrvb3MFUPiQm71qKapo30b6V6oXWOTlreS8lxHcAXWon_Ib955mJ6SuhFTsks0dlDAK2FQ-kM_NaL1grkQV31fEFeza4ivrTns-LslK8_GoLRlXmjl8NKm7dc-XPOKtMvvIz-0huZIHc3HQhXV2k3qPG39XhWV91gXXVuHcR9S9SkqMM9ERGDsP4ezmZb7EsNBFXv2zvi9O2fPqDXxzvhN2lT-udxrlIQv3gCs77sS5n_r-JFVccai0N0Y8hFk">
                <!-- Interactive Hotspots -->
                <div class="absolute inset-0 p-8">
                  <div class="absolute top-1/3 left-1/4 group-hotspot cursor-pointer transition-transform duration-300 hover:scale-110">
                    <div class="bg-primary w-6 h-6 rounded-full border-4 border-white shadow-lg animate-pulse"></div>
                    <div class="absolute top-8 -left-10 bg-white dark:bg-inverse-surface p-2 rounded-lg shadow-md font-label-md text-xs whitespace-nowrap text-on-surface border border-outline-variant/30">San Juan de Dios</div>
                  </div>
                  <div class="absolute bottom-1/4 right-1/3 group-hotspot cursor-pointer transition-transform duration-300 hover:scale-110">
                    <div class="bg-[#bb0017] w-6 h-6 rounded-full border-4 border-white shadow-lg animate-pulse"></div>
                    <div class="absolute top-8 -left-10 bg-white dark:bg-inverse-surface p-2 rounded-lg shadow-md font-label-md text-xs whitespace-nowrap text-on-surface border border-outline-variant/30">Plaza del Carmen</div>
                  </div>
                  <div class="absolute top-1/2 right-1/4 group-hotspot cursor-pointer transition-transform duration-300 hover:scale-110">
                    <div class="bg-primary-container w-6 h-6 rounded-full border-4 border-white shadow-lg animate-pulse"></div>
                    <div class="absolute top-8 -left-10 bg-white dark:bg-inverse-surface p-2 rounded-lg shadow-md font-label-md text-xs whitespace-nowrap text-on-surface border border-outline-variant/30">La Catedral</div>
                  </div>
                </div>
                <!-- Map Overlay UI -->
                <div class="absolute bottom-6 right-6 flex flex-col gap-2">
                  <button class="bg-white/90 backdrop-blur p-2 rounded-lg shadow-md hover:bg-white text-on-surface-variant flex items-center justify-center"><span class="material-symbols-outlined text-lg">add</span></button>
                  <button class="bg-white/90 backdrop-blur p-2 rounded-lg shadow-md hover:bg-white text-on-surface-variant flex items-center justify-center"><span class="material-symbols-outlined text-lg">remove</span></button>
