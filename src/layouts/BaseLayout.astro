---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activePage?: 'nature' | 'culture' | 'heritage' | 'experiences' | 'estancias' | 'home';
  bodyClass?: string;
  isNaturePage?: boolean;
}

const { 
  title, 
  description = "Experiencias turísticas auténticas y personalizadas en Camagüey, Cuba. Grupos pequeños, cultura real, naturaleza y vivencias locales. Contacta por WhatsApp.",
  activePage, 
  bodyClass = "bg-background text-on-background font-body-md overflow-x-hidden", 
  isNaturePage = false 
} = Astro.props;

const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith('/') ? base : `${base}/`;
---

<!DOCTYPE html>
<html class="scroll-smooth" lang="es">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <meta name="description" content={description} />
  
  <!-- Favicon -->
  <link rel="icon" href={`${cleanBase}favicon.svg`} />
  
  <title>{title}</title>
  
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries" is:inline></script>
  
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Libre+Caslon+Text:ital,wght@0,400;0,700;1,400&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  
  <!-- Dynamic Tailwind Configuration -->
  <script define:vars={{ isNaturePage }} is:inline>
    const secondaryColors = isNaturePage ? {
      "secondary": "#006b34",
      "on-secondary-fixed": "#00210c",
      "on-secondary-container": "#f6fff3",
      "secondary-fixed-dim": "#6edd8d",
      "secondary-fixed": "#8afaa7",
      "on-secondary-fixed-variant": "#005227",
      "secondary-container": "#8afaa7"
    } : {
      "secondary": "#bb0017",
      "on-secondary-fixed": "#410003",
      "on-secondary-container": "#fffbff",
      "secondary-fixed-dim": "#ffb3ac",
      "secondary-fixed": "#ffdad6",
      "on-secondary-fixed-variant": "#93000f",
      "secondary-container": "#e41e27"
    };

    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          "colors": {
            "on-primary-fixed-variant": "#005227",
            "inverse-on-surface": "#f8efea",
            "on-primary": "#ffffff",
            "surface-variant": "#e9e1dc",
            "on-error-container": "#93000a",
            "on-tertiary-fixed": "#1c1c18",
            "primary-container": "#008643",
            "outline-variant": "#bdcabc",
            "surface-container": "#f5ece7",
            "inverse-primary": "#6edd8d",
            "primary": "#006b34",
            "on-tertiary": "#ffffff",
            "tertiary-fixed-dim": "#c9c6c0",
            "on-primary-fixed": "#00210c",
            "background": "#fff8f5",
            "inverse-surface": "#34302c",
            "on-error": "#ffffff",
            "surface-bright": "#fff8f5",
            "tertiary-fixed": "#e5e2db",
            "tertiary-container": "#76756f",
            "outline": "#6e7a6e",
            "surface-tint": "#006d35",
            "on-secondary": "#ffffff",
            "primary-fixed-dim": "#6edd8d",
            "on-surface": "#1e1b18",
            "surface": "#fff8f5",
            "surface-container-lowest": "#ffffff",
            "on-background": "#1e1b18",
            "error": "#ba1a1a",
            "surface-container-low": "#fbf2ed",
            "on-tertiary-container": "#fdffdd",
            "primary-fixed": "#8afaa7",
            "surface-container-highest": "#e9e1dc",
            "error-container": "#ffdad6",
            "surface-container-high": "#efe6e2",
            "surface-dim": "#e1d8d4",
            "on-tertiary-fixed-variant": "#474742",
            "on-surface-variant": "#3e4a3f",
            "tertiary": "#5d5c57",
            "on-primary-container": "#f6fff3",
            ...secondaryColors
          },
          "borderRadius": {
            "DEFAULT": "0.25rem",
            "lg": "0.5rem",
            "xl": "0.75rem",
            "full": "9999px"
          },
          "spacing": {
            "unit": "8px",
            "container-max": "1280px",
            "margin-desktop": "40px",
            "margin-mobile": "16px",
            "gutter": "24px"
          },
          "fontFamily": {
            "body-lg": ["Be Vietnam Pro"],
            "label-md": ["Be Vietnam Pro"],
            "display-lg-mobile": ["Libre Caslon Text"],
            "headline-md": ["Libre Caslon Text"],
            "display-lg": ["Libre Caslon Text"],
            "body-md": ["Be Vietnam Pro"],
            "headline-sm": ["Libre Caslon Text"]
          },
          "fontSize": {
            "body-lg": ["18px", { "lineHeight": "1.6", "fontWeight": "400" }],
            "label-md": ["14px", { "lineHeight": "1.2", "letterSpacing": "0.05em", "fontWeight": "600" }],
            "display-lg-mobile": ["36px", { "lineHeight": "1.2", "fontWeight": "700" }],
            "headline-md": ["32px", { "lineHeight": "1.3", "fontWeight": "600" }],
            "display-lg": ["48px", { "lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "700" }],
            "body-md": ["16px", { "lineHeight": "1.6", "fontWeight": "400" }],
            "headline-sm": ["24px", { "lineHeight": "1.4", "fontWeight": "600" }]
          }
        }
      }
    };
  </script>
</head>
<body class={bodyClass}>
  <Navbar activePage={activePage} />
  
  <slot />
  
  <WhatsAppButton />
  
  <Footer />

  <script is:inline>
    // Soft fade-in scroll reveal animation for all page sections
    document.addEventListener('DOMContentLoaded', () => {
      const observerOptions = {
        threshold: 0.1
      };
      
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('opacity-100', 'translate-y-0');
            entry.target.classList.remove('opacity-0', 'translate-y-10');
          }
        });
      }, observerOptions);

      document.querySelectorAll('section > div').forEach(el => {
        // Only apply if they don't have transition-all yet
        if (!el.classList.contains('transition-all')) {
          el.classList.add('transition-all', 'duration-1000', 'opacity-0', 'translate-y-10');
        }
        observer.observe(el);
      });
    });
  </script>
</body>
</html>