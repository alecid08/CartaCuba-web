---
import { tours } from '../data/tours.js';

const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith('/') ? base : `${base}/`;

// Clone elements for infinite loop (since we show up to 4 cards on desktop, we need 4 clones on each side)
const startClones = tours.slice(-4);
const endClones = tours.slice(0, 4);
const allTours = [...startClones, ...tours, ...endClones];
---

<div class="relative w-full overflow-hidden py-4" id="tour-carousel-container">
  <!-- Nav Buttons -->
  <button 
    id="tour-prev" 
    class="absolute top-1/2 -translate-y-1/2 rounded-full flex items-center justify-center shadow-md transition-all hover:scale-105 active:scale-95 cursor-pointer tour-nav-btn"
    aria-label="Tours anteriores"
  >
    <span class="material-symbols-outlined text-2xl font-bold">west</span>
  </button>

  <!-- Track Wrapper -->
  <div class="overflow-hidden w-full py-2">
    <div 
      id="tour-track" 
      class="flex gap-6 py-2"
    >
      {allTours.map((tour) => (
        <div 
          class="tour-card-slide bg-[#E8D8B7] rounded-2xl overflow-hidden border border-outline-variant/20 shadow-sm hover:shadow-md transition-all flex flex-col group relative"
        >
          <!-- Link covering the card for accessible navigation -->
          <a href={`${cleanBase}tours/${tour.id}/`} class="absolute inset-0 z-30" aria-label={`Ver detalles de ${tour.title}`}></a>

          <!-- 1. Imagen del tour (arriba, ocupa ~45% de la card) -->
          <div class="relative h-[45%] overflow-hidden bg-surface-container">
            <img 
              alt={tour.title} 
              class="w-full h-full object-cover group-hover:scale-[1.05] transition-transform duration-300 ease-in-out" 
              src={tour.image}
              loading="lazy"
            />
            <div class="absolute top-4 left-4 z-20 flex gap-2">
              <span class="bg-primary text-white text-[12px] font-label-md px-3 py-1 rounded-full uppercase tracking-wider shadow-sm flex items-center gap-1">
                <span class="material-symbols-outlined text-[14px]" style="font-variation-settings: 'FILL' 1;">{tour.badgeIcon}</span>
                {tour.category}
              </span>
            </div>
          </div>

          <!-- Card Content (55%) -->
          <div class="p-5 flex flex-col h-[55%] justify-between">
            <div class="space-y-2">
              <!-- 2. Nombre del tour — elemento principal, fuente grande, peso bold, color #1F3D2B -->
              <h3 class="font-headline-sm text-base font-bold text-[#1F3D2B] dark:text-[#E8D8B7] line-clamp-2 leading-tight">
                {tour.title}
              </h3>

              <!-- 3. Duración — debajo del nombre, color #C47A2C (ámbar), tamaño ligeramente mayor -->
              <div class="flex items-center gap-1 text-[#C47A2C] font-label-md text-sm font-semibold uppercase tracking-wider">
                <span class="material-symbols-outlined text-[18px]">schedule</span>
                <span>{tour.duration}</span>
              </div>

              <!-- 4. Descripción breve — debajo de duración, fuente normal, color oscuro, máximo 2 líneas -->
              <p class="text-on-surface-variant dark:text-surface-variant font-body-md text-xs line-clamp-2 leading-relaxed">
                {tour.shortDescription}
              </p>
            </div>

            <!-- Price & CTA Button -->
            <div class="space-y-3 pt-2">
              <!-- 5. Precio — debajo de descripción, sin el texto "Precio final garantizado", solo: "Desde $XX USD / persona" -->
              <div class="text-on-surface-variant dark:text-surface-variant text-xs">
                <span>Desde <strong class="text-[#1F3D2B] dark:text-[#E8D8B7] text-base font-bold">${tour.price} USD</strong> / persona</span>
              </div>

              <!-- 6. Botón CTA — al fondo de la card -->
              <a 
                href={`${cleanBase}tours/${tour.id}/`}
                class="w-full bg-[#1F3D2B] text-white hover:bg-[#3E6B48] text-center py-2.5 rounded-full font-label-md transition-all duration-300 flex items-center justify-center gap-2 text-xs font-bold relative z-40"
              >
                <span>Conocer más</span>
                <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Dots Indicators -->
  <div class="flex justify-center gap-2 mt-6" id="tour-dots">
    {tours.map((_, index) => (
      <button 
        class={index === 0 ? 'active' : ''}
        data-index={index}
        aria-label={`Ir al tour ${index + 1}`}
      ></button>
    ))}
  </div>

  <!-- Nav Buttons -->
  <button 
    id="tour-next" 
    class="absolute top-1/2 -translate-y-1/2 rounded-full flex items-center justify-center shadow-md transition-all hover:scale-105 active:scale-95 cursor-pointer tour-nav-btn"
    aria-label="Tours siguientes"
  >
    <span class="material-symbols-outlined text-2xl font-bold">east</span>
  </button>
</div>

<style>
  /* Container Padding (Ensure 1 card visible on mobile, centered within padding) */
  #tour-carousel-container {
    padding-left: 3rem; /* 48px */
    padding-right: 3rem; /* 48px */
  }

  @media (min-width: 768px) {
    #tour-carousel-container {
      padding-left: 4rem; /* 64px */
      padding-right: 4rem; /* 64px */
    }
  }

  /* Nav Buttons Styling */
  .tour-nav-btn {
    width: 44px;
    height: 44px;
    background-color: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #C47A2C;
    z-index: 45;
  }

  #tour-prev {
    left: 4px;
  }
  #tour-next {
    right: 4px;
  }

  @media (min-width: 768px) {
    #tour-prev {
      left: 16px;
    }
    #tour-next {
      right: 16px;
    }
  }

  /* Dots Indicators Styling */
  #tour-dots button {
    width: 10px;
    height: 10px;
    border-radius: 9999px;
    transition: all 0.3s ease-in-out;
    background-color: rgba(31, 61, 43, 0.3); /* #1F3D2B with 30% opacity */
    cursor: pointer;
    border: none;
    padding: 0;
  }

  #tour-dots button.active {
    background-color: #C47A2C;
    width: 24px;
  }

  /* Hide scrollbar for Chrome, Safari and Opera */
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .scrollbar-none {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }

  #tour-track {
    display: flex;
    gap: 1.5rem; /* 24px */
    transition: transform 0.4s ease-in-out;
  }

  .tour-card-slide {
    height: 460px; /* Fixed height for all cards */
    flex: 0 0 100%;
    width: 100%;
    background-color: #E8D8B7;
    transition: background-color 0.3s ease, box-shadow 0.3s ease;
  }
  
  .tour-card-slide:hover {
    background-color: #D4E8D4 !important;
  }

  @media (min-width: 768px) {
    .tour-card-slide {
      flex: 0 0 calc((100% - 1.5rem) / 2);
      width: calc((100% - 1.5rem) / 2);
    }
  }

  @media (min-width: 1025px) {
    .tour-card-slide {
      flex: 0 0 calc((100% - 4.5rem) / 4);
      width: calc((100% - 4.5rem) / 4);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.getElementById('tour-track');
    const prevBtn = document.getElementById('tour-prev');
    const nextBtn = document.getElementById('tour-next');
    
    if (track && prevBtn && nextBtn) {
      const cards = Array.from(track.children);
      const totalOriginals = 5;
      const cloneCount = 4;
      
      let currentIndex = cloneCount; // Start at the first original card
      let isTransitioning = false;
      let transitionTimeout = null;

      const getStep = () => {
        const firstCard = cards[0];
        if (firstCard) {
          return firstCard.getBoundingClientRect().width + 24; // Width + gap (1.5rem = 24px)
        }
        return 320;
      };

      const updateDots = () => {
        const dots = Array.from(document.querySelectorAll('#tour-dots button'));
        if (!dots.length) return;
        
        let activeIndex = (currentIndex - cloneCount) % totalOriginals;
        if (activeIndex < 0) {
          activeIndex += totalOriginals;
        }
        
        dots.forEach((dot, idx) => {
          if (idx === activeIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      };

      const updatePosition = (animate = true) => {
        const step = getStep();
        if (animate) {
          track.style.transition = 'transform 0.4s ease-in-out';
        } else {
          track.style.transition = 'none';
        }
        track.style.transform = `translate3d(${-currentIndex * step}px, 0, 0)`;
        updateDots();
      };

      const handleLoopCheck = () => {
        if (currentIndex >= totalOriginals + cloneCount) {
          currentIndex = cloneCount;
          updatePosition(false);
        } else if (currentIndex < cloneCount) {
          currentIndex = totalOriginals + cloneCount - 1;
          updatePosition(false);
        }
      };

      const setTransitioning = () => {
        isTransitioning = true;
        clearTimeout(transitionTimeout);
        transitionTimeout = setTimeout(() => {
          if (isTransitioning) {
            isTransitioning = false;
            handleLoopCheck();
          }
        }, 500); // 0.4s transition + 100ms safety margin
      };

      // Handle transitions and looping
      track.addEventListener('transitionend', () => {
        isTransitioning = false;
        handleLoopCheck();
      });

      nextBtn.addEventListener('click', () => {
        if (isTransitioning) return;
        setTransitioning();
        currentIndex++;
        updatePosition(true);
      });

      prevBtn.addEventListener('click', () => {
        if (isTransitioning) return;
        setTransitioning();
        currentIndex--;
        updatePosition(true);
      });

      // Dot navigation
      const dots = Array.from(document.querySelectorAll('#tour-dots button'));
      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          if (isTransitioning) return;
          const targetIndex = parseInt(dot.getAttribute('data-index') || '0', 10);
          currentIndex = cloneCount + targetIndex;
          setTransitioning();
          updatePosition(true);
        });
      });

      // Touch swipe support (distinguishing vertical scroll from horizontal swipe)
      let touchStartX = 0;
      let touchStartY = 0;
      let touchEndX = 0;
      let touchEndY = 0;
      let isSwiping = false;

      track.addEventListener('touchstart', (e) => {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        touchEndX = touchStartX;
        touchEndY = touchStartY;
        isSwiping = true;
      }, { passive: true });

      track.addEventListener('touchmove', (e) => {
        if (!isSwiping) return;
        touchEndX = e.touches[0].clientX;
        touchEndY = e.touches[0].clientY;
      }, { passive: true });

      track.addEventListener('touchend', () => {
        if (!isSwiping) return;
        isSwiping = false;
        
        const diffX = touchEndX - touchStartX;
        const diffY = touchEndY - touchStartY;
        
        // Trigger swipe if horizontal movement is greater than vertical and exceeds 40px threshold
        if (Math.abs(diffX) > Math.abs(diffY) && Math.abs(diffX) > 40) {
          if (diffX < 0) {
            // Swipe Left -> Next
            if (isTransitioning) return;
            setTransitioning();
            currentIndex++;
            updatePosition(true);
          } else {
            // Swipe Right -> Prev
            if (isTransitioning) return;
            setTransitioning();
            currentIndex--;
            updatePosition(true);
          }
        }
      });

      // Handle resizing to keep correct position
      window.addEventListener('resize', () => {
        updatePosition(false);
      });

      // Initial alignment
      setTimeout(() => {
        updatePosition(false);
      }, 300);
    }
  });
</script>
