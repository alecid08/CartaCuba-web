---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { tours } from '../../../data/tours.js';
import TourReviews from '../../../components/TourReviews.astro';
import tourData from '../../../data/tours/arte-bohemia.json';
import reviewsData from '../../../data/reviews/arte-bohemia.json';

const baseTour = tours.find(t => t.id === 'arte-bohemia') || {};
const tour = {
  ...baseTour,
  ...tourData
};
const reviews = reviewsData.reviews;
---

<BaseLayout title={`${tour.title} | CartaCuba`} activePage="tours">
  <!-- Hero Section -->
  <section class="relative h-[450px] md:h-[550px] flex items-center overflow-hidden w-full pt-20">
    <div class="absolute inset-0 z-0">
      <img 
        alt={tour.title} 
        class="w-full h-full object-cover" 
        src={tour.image}
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto w-full text-white">
      <div class="max-w-3xl space-y-4">
        <span class="inline-flex items-center gap-2 font-label-md px-4 py-1 rounded-full bg-primary/30 border border-primary-fixed/20 text-primary-fixed uppercase tracking-wider text-xs">
          <span class="material-symbols-outlined text-sm">{tour.badgeIcon}</span>
          {tour.category}
        </span>
        <h1 class="font-display-lg text-display-lg-mobile md:text-5xl font-bold leading-tight drop-shadow-md">
          {tour.title}
        </h1>
        <div class="flex flex-wrap items-center gap-6 text-sm font-medium">
          <div class="flex items-center gap-1">
            <span class="material-symbols-outlined text-primary-fixed">schedule</span>
            <span>{tour.duration}</span>
          </div>
          <div class="flex items-center gap-1">
            <span class="material-symbols-outlined text-primary-fixed">group</span>
            <span>Grupos pequeños (máx. 6)</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Specs Bar -->
  <div class="bg-surface-container py-6 border-b border-outline-variant/30">
    <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div class="border-r border-outline-variant/30 last:border-none">
        <span class="text-xs text-on-surface-variant uppercase tracking-wider block">Precio Desde</span>
        <span class="font-bold text-primary font-headline-sm">{tour.priceDisplay}</span>
      </div>
      <div class="border-r border-outline-variant/30 last:border-none">
        <span class="text-xs text-on-surface-variant uppercase tracking-wider block">Duración</span>
        <span class="font-bold text-on-surface font-headline-sm">{tour.duration}</span>
      </div>
      <div class="border-r border-outline-variant/30 last:border-none">
        <span class="text-xs text-on-surface-variant uppercase tracking-wider block">Dificultad</span>
        <span class="font-bold text-on-surface font-headline-sm">Fácil / Moderada</span>
      </div>
      <div class="last:border-none">
        <span class="text-xs text-on-surface-variant uppercase tracking-wider block">Idioma</span>
        <span class="font-bold text-on-surface font-headline-sm">Español / Inglés</span>
      </div>
    </div>
  </div>

  <main class="py-16 bg-background">
    <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12">
      
      <!-- Content Column (Left) -->
      <div class="lg:col-span-7 space-y-12">
        
        <!-- Description -->
        <section class="space-y-4">
          <h3 class="font-headline-sm text-2xl text-on-surface font-bold">Descripción del Viaje</h3>
          <p class="font-body-lg text-on-surface-variant leading-relaxed">
            {tour.fullDescription}
          </p>
        </section>

        <!-- Gallery Section -->
        <section class="space-y-6">
          <h3 class="font-headline-sm text-2xl text-on-surface font-bold">Cómo vives esta experiencia</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
            {tour.galleryImages.map((img, index) => (
              <button 
                class="gallery-thumb-btn aspect-[4/3] rounded-2xl overflow-hidden border border-outline-variant/20 relative group cursor-pointer"
                data-gallery-idx={index}
              >
                <img src={img} alt={`${tour.title} ${index + 1}`} class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-300" />
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-colors duration-300"></div>
              </button>
            ))}
          </div>

          <!-- Lightbox modal (simple container) -->
          <div id="gallery-lightbox" class="hidden fixed inset-0 z-[100] bg-black/90 flex items-center justify-center p-4">
            <button id="lightbox-close" class="absolute top-6 right-6 text-white text-4xl hover:scale-110 transition-transform"><span class="material-symbols-outlined">close</span></button>
            <button id="lightbox-prev" class="absolute left-6 top-1/2 -translate-y-1/2 text-white text-4xl hover:scale-110 transition-transform"><span class="material-symbols-outlined">chevron_left</span></button>
            <button id="lightbox-next" class="absolute right-6 top-1/2 -translate-y-1/2 text-white text-4xl hover:scale-110 transition-transform"><span class="material-symbols-outlined">chevron_right</span></button>
            <div class="max-w-4xl max-h-[80vh] flex items-center justify-center">
              <img id="lightbox-img" src="" alt="Zoomed view" class="max-w-full max-h-full rounded-2xl object-contain shadow-2xl" />
            </div>
          </div>
        </section>

        <!-- Itinerary -->
        {tour.itinerary && tour.itinerary.length > 0 && (
          <section class="space-y-6">
            <h3 class="font-headline-sm text-2xl text-on-surface font-bold">Itinerario Detallado</h3>
            <div class="relative pl-6 border-l-2 border-primary/20 space-y-8 py-2">
              {tour.itinerary.map((item) => (
                <div class="relative space-y-1 group">
                  <!-- Timeline Dot -->
                  <div class="absolute -left-[31px] top-1.5 w-4 h-4 rounded-full bg-white border-2 border-primary group-hover:bg-primary transition-all"></div>
                  <div class="flex items-center gap-3">
                    <span class="text-xs bg-primary/10 text-primary px-2.5 py-1 rounded-md font-bold uppercase">{item.time}</span>
                    <h4 class="font-bold text-on-surface font-body-lg text-sm">{item.title}</h4>
                  </div>
                  <p class="text-on-surface-variant font-body-md text-sm pl-0 pt-1 leading-relaxed">{item.desc}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Included / Excluded -->
        <section class="grid sm:grid-cols-2 gap-8 p-6 sm:p-8 bg-surface-container-low rounded-3xl border border-outline-variant/30">
          <div>
            <h4 class="font-bold text-on-surface font-body-lg mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-primary">check_circle</span>
              Qué Incluye
            </h4>
            <ul class="space-y-3 text-sm text-on-surface-variant">
              {tour.included.map((inc) => (
                <li class="flex items-start gap-2">
                  <span class="text-primary font-bold">✓</span>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>
          <div>
            <h4 class="font-bold text-on-surface font-body-lg mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-[#bb0017]">cancel</span>
              No Incluye
            </h4>
            <ul class="space-y-3 text-sm text-on-surface-variant">
              {tour.excluded.map((exc) => (
                <li class="flex items-start gap-2">
                  <span class="text-[#bb0017] font-bold">✗</span>
                  <span>{exc}</span>
                </li>
              ))}
            </ul>
          </div>
        </section>



        <!-- Chat with Operator -->
        <section class="bg-primary/5 p-6 rounded-2xl border border-primary/20 flex flex-col sm:flex-row items-center justify-between gap-6">
          <div class="space-y-2 text-center sm:text-left">
            <h4 class="font-bold text-on-surface font-body-lg text-lg">¿Tienes alguna pregunta sobre este tour?</h4>
            <p class="text-on-surface-variant font-body-md text-sm">Chatea directamente con nuestro operador de turismo en tiempo real.</p>
          </div>
          <a 
            href={`https://wa.me/+5351383690?text=Hola,%20tengo%20una%20pregunta%20sobre%20el%20tour:%20"${tour.title}".`}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-[#25D366] hover:bg-[#20ba59] text-white px-6 py-3 rounded-full font-label-md flex items-center gap-2 transition-all hover:scale-105 active:scale-95 shadow-sm whitespace-nowrap"
          >
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.457L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.625 1.451 5.403.002 9.803-4.381 9.806-9.791.001-2.592-1.01-5.031-2.852-6.874a9.71 9.71 0 0 0-6.83-2.781c-5.41 0-9.81 4.384-9.813 9.795-.001 1.57.426 3.102 1.236 4.469l-1.015 3.704 3.828-1.004zM17.15 14.54c-.294-.147-1.74-.858-2.01-.957-.27-.099-.467-.147-.663.148-.196.294-.76.957-.93 1.152-.172.196-.344.22-.638.073-.293-.146-1.242-.457-2.366-1.458-.875-.78-1.465-1.744-1.637-2.038-.172-.294-.018-.453.128-.598.133-.131.294-.343.442-.515.147-.171.196-.293.294-.49.098-.195.049-.367-.025-.515-.074-.147-.663-1.597-.908-2.186-.239-.574-.482-.497-.663-.506-.172-.008-.368-.01-.565-.01-.196 0-.515.074-.784.368-.269.294-1.03 1.005-1.03 2.451 0 1.446 1.053 2.843 1.2 3.039.147.196 2.073 3.166 5.02 4.444.701.304 1.249.485 1.674.62.705.224 1.346.193 1.853.118.565-.084 1.74-.711 1.985-1.396.246-.686.246-1.274.172-1.397-.074-.122-.27-.196-.565-.343z"/></svg>
            <span>Consultar por WhatsApp</span>
          </a>
        </section>

      </div>

      <!-- Booking & Payment Sidebar (Right) -->
      <div class="lg:col-span-5">
        <div class="bg-white dark:bg-inverse-surface border border-outline-variant/30 rounded-3xl p-6 sm:p-8 shadow-md sticky top-28 space-y-6" id="booking-sidebar">
          
          <!-- Tab Headers -->
          <div class="grid grid-cols-2 border-b border-outline-variant/30 pb-3">
            <button 
              id="tab-btn-book" 
              class="tab-btn font-label-md text-label-md text-primary font-bold border-b-2 border-primary pb-2 text-center"
              data-tab="book"
            >
              1. Reservar (WA)
            </button>
            <button 
              id="tab-btn-pay" 
              class="tab-btn font-label-md text-label-md text-on-surface-variant dark:text-surface-variant pb-2 text-center"
              data-tab="pay"
            >
              2. Pago Seguro (Sim)
            </button>
          </div>

          <!-- Tab Content 1: Book Form -->
          <div id="tab-content-book" class="tab-content space-y-4">
            <div class="bg-surface-container-low p-4 rounded-xl text-xs space-y-1">
              <span class="text-on-surface-variant block uppercase tracking-wider">Desde ${tour.price} USD por persona</span>
              <div class="flex justify-between items-baseline">
                <span class="font-bold text-primary text-xl" id="tour-base-price" data-price={tour.price}>${tour.price} USD</span>
                <span class="text-on-surface-variant" id="total-estimation-text">Total: ${tour.price} USD</span>
              </div>
            </div>

            <form id="whatsapp-booking-form" class="space-y-4">
              <div class="space-y-1">
                <label for="book-name" class="block text-xs font-bold text-on-surface-variant uppercase tracking-wider">Nombre Completo *</label>
                <input 
                  type="text" 
                  id="book-name" 
                  required 
                  class="w-full bg-background border border-outline-variant rounded-xl px-4 py-2.5 text-sm text-on-surface focus:ring-primary focus:ring-primary"
                  placeholder="Ej. Sarah Jenkins"
                />
              </div>

              <div class="space-y-1">
                <label for="book-email" class="block text-xs font-bold text-on-surface-variant uppercase tracking-wider">Correo Electrónico *</label>
                <input 
                  type="email" 
                  id="book-email" 
                  required 
                  class="w-full bg-background border border-outline-variant rounded-xl px-4 py-2.5 text-sm text-on-surface focus:ring-primary focus:ring-primary"
                  placeholder="Ej. sarah@example.com"
                />
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1">
                  <label for="book-date" class="block text-xs font-bold text-on-surface-variant uppercase tracking-wider">Fecha del Viaje *</label>
                  <input 
                    type="date" 
                    id="book-date" 
                    required 
                    class="w-full bg-background border border-outline-variant rounded-xl px-3 py-2 text-sm text-on-surface focus:ring-primary focus:ring-primary"
                  />
                </div>
                <div class="space-y-1">
                  <label for="book-people" class="block text-xs font-bold text-on-surface-variant uppercase tracking-wider">Viajeros *</label>
                  <input 
                    type="number" 
                    id="book-people" 
                    min="1" 
                    max="10" 
                    value="1" 
                    required 
                    class="w-full bg-background border border-outline-variant rounded-xl px-3 py-2 text-sm text-on-surface focus:ring-primary focus:ring-primary"
                  />
                </div>
              </div>

              <div class="space-y-1">
                <label for="book-notes" class="block text-xs font-bold text-on-surface-variant uppercase tracking-wider">Notas o Petición Especial</label>
                <textarea 
                  id="book-notes" 
                  rows="3" 
                  class="w-full bg-background border border-outline-variant rounded-xl px-4 py-2.5 text-sm text-on-surface focus:ring-primary focus:ring-primary"
                  placeholder="Ej. Alergias alimenticias, requerimiento especial de idioma, etc."
                ></textarea>
              </div>

              <button 
                type="submit" 
                class="w-full bg-[#25D366] hover:bg-[#20ba59] text-white py-4 rounded-full font-label-md text-label-md flex items-center justify-center gap-2 transition-all hover:scale-[1.02] active:scale-[0.98] shadow-md mt-6"
              >
                <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.457L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.625 1.451 5.403.002 9.803-4.381 9.806-9.791.001-2.592-1.01-5.031-2.852-6.874a9.71 9.71 0 0 0-6.83-2.781c-5.41 0-9.81 4.384-9.813 9.795-.001 1.57.426 3.102 1.236 4.469l-1.015 3.704 3.828-1.004zM17.15 14.54c-.294-.147-1.74-.858-2.01-.957-.27-.099-.467-.147-.663.148-.196.294-.76.957-.93 1.152-.172.196-.344.22-.638.073-.293-.146-1.242-.457-2.366-1.458-.875-.78-1.465-1.744-1.637-2.038-.172-.294-.018-.453.128-.598.133-.131.294-.343.442-.515.147-.171.196-.293.294-.49.098-.195.049-.367-.025-.515-.074-.147-.663-1.597-.908-2.186-.239-.574-.482-.497-.663-.506-.172-.008-.368-.01-.565-.01-.196 0-.515.074-.784.368-.269.294-1.03 1.005-1.03 2.451 0 1.446 1.053 2.843 1.2 3.039.147.196 2.073 3.166 5.02 4.444.701.304 1.249.485 1.674.62.705.224 1.346.193 1.853.118.565-.084 1.74-.711 1.985-1.396.246-.686.246-1.274.172-1.397-.074-.122-.27-.196-.565-.343z"/></svg>
                <span>Enviar Reserva por WhatsApp</span>
              </button>
            </form>
          </div>

          <!-- Tab Content 2: Payment Gateway (Simulated) -->
          <div id="tab-content-pay" class="tab-content hidden space-y-4 relative">
            
            <!-- Success Overlay -->
            <div id="payment-success-overlay" class="hidden absolute inset-0 bg-white dark:bg-inverse-surface z-30 flex flex-col items-center justify-center text-center space-y-4 py-8">
              <div class="w-16 h-16 rounded-full bg-primary/10 text-primary flex items-center justify-center animate-bounce">
                <span class="material-symbols-outlined text-4xl">check_circle</span>
              </div>
              <h4 class="font-headline-sm text-lg font-bold text-on-surface">¡Pago Simulado con Éxito!</h4>
              <p class="text-xs text-on-surface-variant max-w-xs leading-relaxed">
                Su pago ha sido procesado de forma simulada. Por favor, complete el envío de la reserva por WhatsApp para coordinar los detalles con el operador.
              </p>
              <button 
                id="success-done-btn"
                class="bg-primary text-white text-xs px-6 py-2.5 rounded-full font-label-md"
              >
                Volver a la Reserva
              </button>
            </div>

            <!-- Loader Overlay -->
            <div id="payment-loading-overlay" class="hidden absolute inset-0 bg-white/80 dark:bg-inverse-surface/80 z-20 flex flex-col items-center justify-center text-center space-y-3">
              <div class="w-10 h-10 border-4 border-primary border-t-transparent rounded-full animate-spin"></div>
              <span class="text-sm font-label-md text-primary">Procesando pago seguro...</span>
            </div>

            <div class="bg-surface-container-low p-4 rounded-xl text-xs space-y-1">
              <span class="text-on-surface-variant block uppercase tracking-wider">Total a Pagar</span>
              <div class="flex justify-between items-baseline">
                <span class="font-bold text-primary text-xl" id="payment-total-text">${tour.price} USD</span>
                <span class="text-on-surface-variant" id="payment-people-count">1 viajero</span>
              </div>
            </div>

            <form id="simulated-payment-form" class="space-y-4">
              <div class="space-y-1">
                <label for="pay-name" class="block text-xs font-bold text-on-surface-variant uppercase tracking-wider">Titular de la Tarjeta *</label>
                <input 
                  type="text" 
                  id="pay-name" 
                  required 
                  class="w-full bg-background border border-outline-variant rounded-xl px-4 py-2.5 text-sm text-on-surface focus:ring-primary focus:ring-primary"
                  placeholder="Ej. Sarah Jenkins"
                />
              </div>

              <div class="space-y-1">
                <label for="pay-card" class="block text-xs font-bold text-on-surface-variant uppercase tracking-wider">Número de Tarjeta *</label>
                <div class="relative">
                  <input 
                    type="text" 
                    id="pay-card" 
                    required 
                    pattern="[0-9]{16}"
                    maxlength="16"
                    class="w-full bg-background border border-outline-variant rounded-xl pl-4 pr-12 py-2.5 text-sm text-on-surface focus:ring-primary focus:ring-primary"
                    placeholder="4111 2222 3333 4444"
                  />
                  <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant">credit_card</span>
                </div>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1">
                  <label for="pay-expiry" class="block text-xs font-bold text-on-surface-variant uppercase tracking-wider">Vencimiento *</label>
                  <input 
                    type="text" 
                    id="pay-expiry" 
                    required 
                    pattern="(0[1-9]|1[0-2])\/[2-9][0-9]"
                    maxlength="5"
                    class="w-full bg-background border border-outline-variant rounded-xl px-3 py-2 text-sm text-on-surface focus:ring-primary focus:ring-primary"
                    placeholder="MM/AA"
                  />
                </div>
                <div class="space-y-1">
                  <label for="pay-cvv" class="block text-xs font-bold text-on-surface-variant uppercase tracking-wider">CVV *</label>
                  <input 
                    type="password" 
                    id="pay-cvv" 
                    required 
                    pattern="[0-9]{3,4}"
                    maxlength="4"
                    class="w-full bg-background border border-outline-variant rounded-xl px-3 py-2 text-sm text-on-surface focus:ring-primary focus:ring-primary"
                    placeholder="123"
                  />
                </div>
              </div>

              <button 
                type="submit" 
                class="w-full bg-primary hover:bg-primary-container text-white py-4 rounded-full font-label-md text-label-md flex items-center justify-center gap-2 transition-all hover:scale-[1.02] active:scale-[0.98] shadow-md mt-6"
              >
                <span class="material-symbols-outlined text-[18px]">lock</span>
                <span>Procesar Pago Seguro</span>
              </button>
            </form>
          </div>

        </div>
      </div>

    </div>
  </main>

  <TourReviews tourTitle={tour.title} reviews={reviews} />
</BaseLayout>

<script define:vars={{ tourTitle: tour.title }}>
  document.addEventListener('DOMContentLoaded', () => {
    // Gallery Lightbox functionality
    const thumbs = document.querySelectorAll('.gallery-thumb-btn');
    const lightbox = document.getElementById('gallery-lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const closeBtn = document.getElementById('lightbox-close');
    const prevBtn = document.getElementById('lightbox-prev');
    const nextBtn = document.getElementById('lightbox-next');
    
    let activeIdx = 0;
    const imagesList = Array.from(thumbs).map(btn => btn.querySelector('img').src);

    function openLightbox(idx) {
      activeIdx = idx;
      if (lightboxImg && lightbox) {
        lightboxImg.src = imagesList[activeIdx];
        lightbox.classList.remove('hidden');
      }
    }

    function closeLightbox() {
      if (lightbox) {
        lightbox.classList.add('hidden');
      }
    }

    function slideLightbox(dir) {
      activeIdx += dir;
      if (activeIdx < 0) activeIdx = imagesList.length - 1;
      if (activeIdx >= imagesList.length) activeIdx = 0;
      if (lightboxImg) {
        lightboxImg.src = imagesList[activeIdx];
      }
    }

    thumbs.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const idx = parseInt(e.currentTarget.getAttribute('data-gallery-idx') || '0', 10);
        openLightbox(idx);
      });
    });

    if (closeBtn) closeBtn.addEventListener('click', closeLightbox);
    if (prevBtn) prevBtn.addEventListener('click', () => slideLightbox(-1));
    if (nextBtn) nextBtn.addEventListener('click', () => slideLightbox(1));
    
    // Close lightbox on escape key
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight' && lightbox && !lightbox.classList.contains('hidden')) slideLightbox(1);
      if (e.key === 'ArrowLeft' && lightbox && !lightbox.classList.contains('hidden')) slideLightbox(-1);
    });

    // Tab switching functionality
    const tabBookBtn = document.getElementById('tab-btn-book');
    const tabPayBtn = document.getElementById('tab-btn-pay');
    const contentBook = document.getElementById('tab-content-book');
    const contentPay = document.getElementById('tab-content-pay');

    function switchTab(tabId) {
      if (tabId === 'book') {
        tabBookBtn.classList.add('text-primary', 'font-bold', 'border-b-2', 'border-primary');
        tabBookBtn.classList.remove('text-on-surface-variant', 'dark:text-surface-variant');
        tabPayBtn.classList.remove('text-primary', 'font-bold', 'border-b-2', 'border-primary');
        tabPayBtn.classList.add('text-on-surface-variant', 'dark:text-surface-variant');
        contentBook.classList.remove('hidden');
        contentPay.classList.add('hidden');
      } else {
        tabPayBtn.classList.add('text-primary', 'font-bold', 'border-b-2', 'border-primary');
        tabPayBtn.classList.remove('text-on-surface-variant', 'dark:text-surface-variant');
        tabBookBtn.classList.remove('text-primary', 'font-bold', 'border-b-2', 'border-primary');
        tabBookBtn.classList.add('text-on-surface-variant', 'dark:text-surface-variant');
        contentPay.classList.remove('hidden');
        contentBook.classList.add('hidden');
      }
    }

    if (tabBookBtn) tabBookBtn.addEventListener('click', () => switchTab('book'));
    if (tabPayBtn) tabPayBtn.addEventListener('click', () => switchTab('pay'));

    // Price estimation updates
    const basePriceElement = document.getElementById('tour-base-price');
    const peopleInput = document.getElementById('book-people');
    const totalEstText = document.getElementById('total-estimation-text');
    const payTotalText = document.getElementById('payment-total-text');
    const payPeopleCount = document.getElementById('payment-people-count');

    function updateCalculations() {
      if (basePriceElement && peopleInput) {
        const basePrice = parseInt(basePriceElement.getAttribute('data-price') || '0', 10);
        const people = parseInt(peopleInput.value || '1', 10);
        const total = basePrice * people;
        
        if (totalEstText) totalEstText.innerText = `Total: $${total} USD`;
        if (payTotalText) payTotalText.innerText = `$${total} USD`;
        if (payPeopleCount) payPeopleCount.innerText = `${people} ${people === 1 ? 'viajero' : 'viajeros'}`;
      }
    }

    if (peopleInput) {
      peopleInput.addEventListener('input', updateCalculations);
      peopleInput.addEventListener('change', updateCalculations);
    }

    // WhatsApp Booking Form Submission
    const bookingForm = document.getElementById('whatsapp-booking-form');
    if (bookingForm) {
      bookingForm.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const name = document.getElementById('book-name').value;
        const email = document.getElementById('book-email').value;
        const date = document.getElementById('book-date').value;
        const people = document.getElementById('book-people').value;
        const notes = document.getElementById('book-notes').value || 'Ninguna';

        const message = `Hola CartaCuba! Me gustaría oficializar mi reserva para el tour:
*"${tourTitle}"*

*Detalles de la Reserva:*
• *Nombre:* ${name}
• *Correo:* ${email}
• *Fecha:* ${date}
• *Viajeros:* ${people}
• *Petición Especial:* ${notes}

Quedo atento a la confirmación de la disponibilidad y métodos de pago. ¡Gracias!`;

        const waUrl = `https://wa.me/+5351383690?text=${encodeURIComponent(message)}`;
        window.open(waUrl, '_blank');
      });
    }

    // Simulated Payment Submission
    const paymentForm = document.getElementById('simulated-payment-form');
    const loadingOverlay = document.getElementById('payment-loading-overlay');
    const successOverlay = document.getElementById('payment-success-overlay');
    const successDoneBtn = document.getElementById('success-done-btn');

    if (paymentForm) {
      paymentForm.addEventListener('submit', (e) => {
        e.preventDefault();
        
        // Show simulated loading
        if (loadingOverlay) loadingOverlay.classList.remove('hidden');
        
        setTimeout(() => {
          // Hide loading
          if (loadingOverlay) loadingOverlay.classList.add('hidden');
          // Show success screen
          if (successOverlay) successOverlay.classList.remove('hidden');
        }, 2000);
      });
    }

    if (successDoneBtn) {
      successDoneBtn.addEventListener('click', () => {
        if (successOverlay) successOverlay.classList.add('hidden');
        if (paymentForm) paymentForm.reset();
        switchTab('book');
      });
    }
  });
</script>
