---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import TourCard from '../components/TourCard.astro';

const whatsappBaseUrl = "https://wa.me/5350000000";

const experiences = [
  {
    title: "Avistamiento de Aves en la Sierra del Chorrillo",
    description: "Adéntrate en los senderos sombreados de la Sierra del Chorrillo para contemplar al Tocororo y al Zunzún en su hábitat natural. Guiado por naturalistas locales dedicados a la conservación de nuestra biodiversidad.",
    image: "https://lh3.googleusercontent.com/aida-public/AB6AXuAp5nAvWqrvgNRD82KSdFM8hErt-mCakDkYoHjsb_49A-uxGM6Lh1jI9e5Apt-EExz8mNmO1OjmMDpDtykz1o2q5r8XFnGxxZdPZ4Q5_G-y2K88i3qtgsI4kmv8A5xgHSXLrPW6bjPTQw80ZRECAgmM-cTYqjgemkyLYhCFQSYsFZ96C_PyKFtOvUvfykmleIToDs03bpzvLoPkY_OOfWan3-vzJfTcM8QG8TMIAlq_36qK1yUd2bvHOk3lxRVJ1QO8vfKF8IRFjPY",
    message: "Hola, me interesa reservar la experiencia de Avistamiento de Aves en la Sierra del Chorrillo.",
    alternativesTitle: "Senderos Alternativos de Igual Belleza",
    alternatives: [
      {
        title: "Paseo por el Dosel en Limones-Tuabaquey",
        description: "Una caminata suspendida entre helechos gigantes y pasadizos de piedra caliza."
      },
      {
        title: "Safari Fotográfico en la Sabana de Najasa",
        description: "Explora los palmares prehistóricos y avista aves endémicas en llanuras abiertas."
      },
      {
        title: "Jornada Silvestre en Cayo Sabinal",
        description: "Una inmersión entre lagunas costeras llenas de flamencos y playas vírgenes."
      }
    ]
  },
  {
    title: "Taller Ancestral de Barro y Alfarería",
    description: "Siente la arcilla de Camagüey moldearse bajo tus manos. Comparte una tarde con maestros artesanos que custodian una tradición alfarera de más de 500 años en sus talleres históricos.",
    image: "https://lh3.googleusercontent.com/aida-public/AB6AXuBEUzMaxQGf76bMPOMV9IjzwWGYhY8uiMS0-tcT33gwDFkpqFWEOAF8VGVCtTibOTM-UCGUu65MEIkyCeaYLyDQ_Q87jxFlFbxQY6ZbHe21mHh50xsPoqW0Cuub4Qun96mMoojv6ZnDeBdihS9uOKbAB0UBw0Ov0b4xBEgWfaSV9Dljm1-1a-iTNn0GU3Ktv1mYUgnX2fy216pg6q3m08DC2wZfJbfqqn90Az4TNBDDWu8cTdgFe6llXYqr3qiTa6zU5ZkeDzgv2b8",
    message: "Hola, me interesa reservar el Taller Ancestral de Barro y Alfarería.",
    alternativesTitle: "Talleres Creativos Igualmente Enriquecedores",
    alternatives: [
      {
        title: "Taller de Talabartería y Cuero Colonial",
        description: "Aprende el arte del repujado y corte del cuero junto a talabarteros locales."
      },
      {
        title: "Tejido Artístico en Fibras de Palma",
        description: "Domina la técnica tradicional del tejido de yarey para crear sombreros y tapices."
      },
      {
        title: "Secretos de la Cocina Agramontina",
        description: "Prepara platos típicos camagüeyanos usando ingredientes locales y de temporada."
      }
    ]
  },
  {
    title: "Ruta del Laberinto y Patios Coloniales",
    description: "Camina por el laberinto urbano diseñado en la época colonial para despistar a los piratas. Descubre los patios interiores y tinajones más bellos de la ciudad, habitualmente cerrados al público.",
    image: "https://lh3.googleusercontent.com/aida-public/AB6AXuChv-vowG9d03HtQirv__UJDgtUcZIPm9yg8qFhoFhulqs_z_1Al73RjgayNpw_4JW9KCn7gzkP87-cQj3SraSYdbej78YvCUqw9uS1888KTLXwVJslmarZjWSarP4l-tLYUrVbFh5RR0P_eifLXzjZJs77oI6UDq5_6ak1TL4FF3-NSrHarAmCL-4zKQ94j8Wg6DIhm38ojZCqYM-38Y65wZaT0xkfrg3S5g9bsUPGW3FUHtD0bV0ba6TD6TqG6y-Fc7fHSyuTJkQ",
    message: "Hola, me interesa reservar la Ruta del Laberinto y Patios Coloniales.",
    alternativesTitle: "Exploraciones Históricas de Gran Encanto",
    alternatives: [
      {
        title: "Paseo del Arte con Martha Jiménez",
        description: "Visita el estudio de la célebre artista y descubre sus esculturas urbanas en Plaza del Carmen."
      },
      {
        title: "Secretos de San Juan de Dios",
        description: "Una inmersión arquitectónica detallada en el conjunto colonial mejor conservado de Cuba."
      },
      {
        title: "Leyendas y Candiles Nocturnos",
        description: "Recorre callejones misteriosos bajo el cálido brillo de los faroles camagüeyanos."
      }
    ]
  }
];
---

<BaseLayout title="Experiencias & Actividades | CartaCuba" activePage="experiences" bodyClass="bg-background text-on-background font-body-md overflow-x-hidden">
  <!-- Hero Section -->
  <HeroSection
    bgImage="https://lh3.googleusercontent.com/aida-public/AB6AXuDYmYQ5zTF7BpjmvbLqeuCNtWHL3vljSmflbdnKrZnsztO2gV6oJACLF6Sbzcmibitw-sP9jQXV_vM7WIt4KJ53UKFof4bTYczIqhDZErQ1Xw1xWSATKgQ1QxEQSgpQpcSJIWW2nDVKD7_Wj-kNsRNvTM2V2SQHd0sdDKA6u3H8Kq7uHwWux8JNAUXruNa6-ltkpZMYx6TscW0Yy6RUZ6cBnbEBR656SKhleiir1TYRVRgVaS8Y1tJIsgDZj0C5t_POZWgpSJF9Xdk"
    badgeText="Experiencias Sostenibles"
    badgeClass="inline-block bg-secondary text-on-secondary px-4 py-1 rounded-full text-label-md uppercase tracking-widest"
    title="Voces y Vivencias en el Corazón de <span class='text-primary italic font-normal'>Camagüey</span>"
    description="Historias reales y recorridos auténticos para conectar con el alma de Cuba a través del turismo sostenible. Vive la magia del cuidado y respeto por el entorno."
    heightClass="min-h-[85vh] pt-24"
  >
    <a class="px-8 py-4 bg-primary text-on-primary rounded-full font-bold flex items-center gap-2 hover:bg-primary-container transition-all" href="#experiencias-list">
      Ver Experiencias
      <span class="material-symbols-outlined">arrow_downward</span>
    </a>
  </HeroSection>

  <!-- Stats Bar -->
  <div class="bg-surface-container py-12 border-y border-outline-variant/30">
    <div class="px-margin-desktop grid grid-cols-2 md:grid-cols-4 gap-gutter text-center max-w-container-max mx-auto">
      <div>
        <div class="font-headline-md text-primary">4.9/5</div>
        <div class="font-label-md text-on-surface-variant">Satisfacción Promedio</div>
      </div>
      <div>
        <div class="font-headline-md text-primary">1.2k+</div>
        <div class="font-label-md text-on-surface-variant">Viajes Sostenibles</div>
      </div>
      <div>
        <div class="font-headline-md text-primary">98%</div>
        <div class="font-label-md text-on-surface-variant font-medium">Abastecimiento Local</div>
      </div>
      <div>
        <div class="font-headline-md text-primary">15k</div>
        <div class="font-label-md text-on-surface-variant">Árboles Plantados</div>
      </div>
    </div>
  </div>

  <!-- Experiences Grid Section -->
  <section class="py-24 px-margin-desktop bg-background" id="experiencias-list">
    <div class="max-w-container-max mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-display-lg text-display-lg text-on-background mb-4">Experiencias Destacadas</h2>
        <div class="w-24 h-1 bg-secondary mx-auto mb-6"></div>
        <p class="font-body-lg text-on-surface-variant max-w-2xl mx-auto">
          Diseñadas meticulosamente para generar impacto positivo y memorias imborrables.
        </p>
      </div>

      <div class="space-y-24">
        {experiences.map((exp, idx) => (
          <div class={`grid grid-cols-1 lg:grid-cols-12 gap-12 items-center ${idx % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
            <!-- Image Area -->
            <div class={`lg:col-span-6 relative group ${idx % 2 === 1 ? 'lg:order-last' : ''}`}>
              <div class="leaf-corner overflow-hidden aspect-[4/3] shadow-xl border border-outline-variant/30">
                <img 
                  alt={exp.title} 
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" 
                  src={exp.image}
                />
              </div>
            </div>

            <!-- Content Area -->
            <div class="lg:col-span-6 space-y-6">
              <h3 class="font-headline-md text-headline-md text-primary font-semibold">{exp.title}</h3>
              <p class="font-body-lg text-body-lg text-on-surface-variant">{exp.description}</p>
              
              <!-- WhatsApp CTA -->
              <div>
                <a 
                  href={`https://wa.me/5350000000?text=${encodeURIComponent(exp.message)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 bg-[#25D366] text-white px-6 py-3 rounded-full font-label-md hover:bg-[#20ba59] transition-all shadow-sm transform hover:scale-105 active:scale-95"
                >
                  <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.457L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.625 1.451 5.403.002 9.803-4.381 9.806-9.791.001-2.592-1.01-5.031-2.852-6.874a9.71 9.71 0 0 0-6.83-2.781c-5.41 0-9.81 4.384-9.813 9.795-.001 1.57.426 3.102 1.236 4.469l-1.015 3.704 3.828-1.004zM17.15 14.54c-.294-.147-1.74-.858-2.01-.957-.27-.099-.467-.147-.663.148-.196.294-.76.957-.93 1.152-.172.196-.344.22-.638.073-.293-.146-1.242-.457-2.366-1.458-.875-.78-1.465-1.744-1.637-2.038-.172-.294-.018-.453.128-.598.133-.131.294-.343.442-.515.147-.171.196-.293.294-.49.098-.195.049-.367-.025-.515-.074-.147-.663-1.597-.908-2.186-.239-.574-.482-.497-.663-.506-.172-.008-.368-.01-.565-.01-.196 0-.515.074-.784.368-.269.294-1.03 1.005-1.03 2.451 0 1.446 1.053 2.843 1.2 3.039.147.196 2.073 3.166 5.02 4.444.701.304 1.249.485 1.674.62.705.224 1.346.193 1.853.118.565-.084 1.74-.711 1.985-1.396.246-.686.246-1.274.172-1.397-.074-.122-.27-.196-.565-.343z"/>
                  </svg>
                  Reservar en WhatsApp
                </a>
              </div>

              <!-- Visible Alternatives Section -->
              <div class="bg-surface-container p-6 rounded-2xl border-l-4 border-primary mt-6">
                <h4 class="font-headline-sm text-[18px] text-on-surface font-semibold mb-3 flex items-center gap-2">
                  <span class="material-symbols-outlined text-primary">explore</span>
                  {exp.alternativesTitle}
                </h4>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                  {exp.alternatives.map((alt) => (
                    <div class="space-y-1">
                      <span class="text-label-md text-primary font-bold block">{alt.title}</span>
                      <p class="text-[13px] text-on-surface-variant leading-relaxed">{alt.description}</p>
                    </div>
                  ))}
                </div>
              </div>

            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery Section -->
  <section class="py-24 bg-surface-container-lowest">
    <div class="px-margin-desktop max-w-container-max mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-display-lg text-display-lg text-on-background mb-4">Momentos Capturados</h2>
        <div class="w-24 h-1 bg-secondary mx-auto mb-6"></div>
        <p class="font-body-lg text-on-surface-variant max-w-2xl mx-auto">Vistazos genuinos de las aventuras compartidas por nuestra comunidad.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="md:col-span-2 group relative overflow-hidden rounded-xl leaf-corner h-96">
          <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src="https://lh3.googleusercontent.com/aida-public/AB6AXuChv-vowG9d03HtQirv__UJDgtUcZIPm9yg8qFhoFhulqs_z_1Al73RjgayNpw_4JW9KCn7gzkP87-cQj3SraSYdbej78YvCUqw9uS1888KTLXwVJslmarZjWSarP4l-tLYUrVbFh5RR0P_eifLXzjZJs77oI6UDq5_6ak1TL4FF3-NSrHarAmCL-4zKQ94j8Wg6DIhm38ojZCqYM-38Y65wZaT0xkfrg3S5g9bsUPGW3FUHtD0bV0ba6TD6TqG6y-Fc7fHSyuTJkQ" alt="Plaza colonial"/>
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
            <p class="text-white font-label-md flex items-center gap-2"><span class="material-symbols-outlined">location_on</span> Plaza del Centro Histórico</p>
          </div>
        </div>
        <div class="group relative overflow-hidden rounded-xl h-96">
          <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBEUzMaxQGf76bMPOMV9IjzwWGYhY8uiMS0-tcT33gwDFkpqFWEOAF8VGVCtTibOTM-UCGUu65MEIkyCeaYLyDQ_Q87jxFlFbxQY6ZbHe21mHh50xsPoqW0Cuub4Qun96mMoojv6ZnDeBdihS9uOKbAB0UBw0Ov0b4xBEgWfaSV9Dljm1-1a-iTNn0GU3Ktv1mYUgnX2fy216pg6q3m08DC2wZfJbfqqn90Az4TNBDDWu8cTdgFe6llXYqr3qiTa6zU5ZkeDzgv2b8" alt="Taller alfarero"/>
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
            <p class="text-white font-label-md flex items-center gap-2"><span class="material-symbols-outlined">restaurant</span> Delicias Locales</p>
          </div>
        </div>
        <div class="group relative overflow-hidden rounded-xl h-96">
          <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAp5nAvWqrvgNRD82KSdFM8hErt-mCakDkYoHjsb_49A-uxGM6Lh1jI9e5Apt-EExz8mNmO1OjmMDpDtykz1o2q5r8XFnGxxZdPZ4Q5_G-y2K88i3qtgsI4kmv8A5xgHSXLrPW6bjPTQw80ZRECAgmM-cTYqjgemkyLYhCFQSYsFZ96C_PyKFtOvUvfykmleIToDs03bpzvLoPkY_OOfWan3-vzJfTcM8QG8TMIAlq_36qK1yUd2bvHOk3lxRVJ1QO8vfKF8IRFjPY" alt="Sierra del Chorrillo"/>
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
            <p class="text-white font-label-md flex items-center gap-2"><span class="material-symbols-outlined">visibility</span> Observación de Aves</p>
          </div>
        </div>
        <div class="md:col-span-4 group relative overflow-hidden rounded-xl h-[500px]">
          <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA06H2kdDNtrcl_LllcB5VvXbgbkTS1Jza6oC93410HJ2AObo4EvxPmdLTUDHJMQe8ct3h3KiRZ9NesZJVa3oWGICPNwxB0w-L4h-nKbWr5EUWABtzqGbQWIbBKt6dm5ayoeMiP0ef4sGIa-SGjM4y-mNL8vxfoaDhhKeO-9D53aDpRYCH-HIFd9bkWf-GxCJyW4spzOE_mhR3hpOEowTPj1_tuIorJxwPq9FgW0_U9bd8R3hRG5HDkjK0K09GQX5MwT2-Ybe2gRWA" alt="Patrimonio Arquitectonico"/>
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-8">
            <div>
              <p class="text-white font-headline-sm mb-2">Recorrido Arquitectónico Patrimonial</p>
              <p class="text-white/80 font-body-md">Senderos por la historia, guiados por quienes la viven día a día.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 relative overflow-hidden bg-primary text-on-primary">
    <div class="absolute top-0 right-0 w-1/2 h-full opacity-10">
      <span class="material-symbols-outlined text-[400px] -rotate-12 transform translate-x-24">nature</span>
    </div>
    <div class="relative z-10 px-margin-desktop text-center">
      <h2 class="font-display-lg text-display-lg mb-8">¿Listo para escribir tu propia historia?</h2>
      <p class="font-body-lg mb-12 max-w-2xl mx-auto opacity-90">
        Únete a la comunidad de CartaCuba y emprende un viaje que deja una huella positiva en la biodiversidad y la cultura de Cuba.
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-6">
        <a href={`https://wa.me/5350000000?text=${encodeURIComponent("Hola, me gustaría conversar con un experto para diseñar un viaje a mi medida.")}`} target="_blank" rel="noopener noreferrer" class="px-10 py-5 bg-on-primary text-primary rounded-full font-bold text-lg hover:bg-primary-fixed transition-all flex items-center gap-3">
          Contactar con un Experto
          <span class="material-symbols-outlined">explore</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
