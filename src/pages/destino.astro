  btnUrlMode.addEventListener('click', () => {
    currentInputMode = 'url';
    btnUrlMode.className = "text-primary border-b-2 border-primary font-label-md text-sm pb-2";
    btnFileMode.className = "text-on-surface-variant font-label-md text-sm pb-2 hover:text-primary";
    urlInputContainer.classList.replace('hidden', 'block');
    fileInputContainer.classList.replace('block', 'hidden');
    document.getElementById('img-file').value = ''; // Reset file input
  });

  btnFileMode.addEventListener('click', () => {
    currentInputMode = 'file';
    btnFileMode.className = "text-primary border-b-2 border-primary font-label-md text-sm pb-2";
    btnUrlMode.className = "text-on-surface-variant font-label-md text-sm pb-2 hover:text-primary";
    fileInputContainer.classList.replace('hidden', 'block');
    urlInputContainer.classList.replace('block', 'hidden');
    document.getElementById('img-url').value = ''; // Reset url input
  });

  // Render gallery function
  function renderGallery() {
    galleryGrid.innerHTML = '';
    const isEditMode = editToggle.checked;

    images.forEach(img => {
      const card = document.createElement('div');
      card.className = "group relative overflow-hidden rounded-2xl aspect-square shadow-sm hover:shadow-md transition-all duration-300 bg-surface-container";
      
      // Image tag
      const imgTag = document.createElement('img');
      imgTag.src = img.url;
      imgTag.alt = img.caption;
      imgTag.className = "w-full h-full object-cover transition-transform duration-700 group-hover:scale-105";
      imgTag.loading = "lazy";
      imgTag.onerror = function() {
        // Fallback for broken URLs
        this.src = "https://images.unsplash.com/photo-1590523277543-a94d2e4eb00b?w=600&auto=format&fit=crop";
      };

      // Caption Overlay container
      const overlay = document.createElement('div');
      overlay.className = "absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6";
      
      const captionText = document.createElement('p');
      captionText.className = "text-white font-label-md text-sm flex items-center gap-2";
      captionText.innerHTML = `<span class="material-symbols-outlined text-lg">image</span> ${img.caption}`;
      overlay.appendChild(captionText);

      card.appendChild(imgTag);
      card.appendChild(overlay);

      // Delete Button (only visible in edit mode)
      if (isEditMode) {
        const deleteBtn = document.createElement('button');
        deleteBtn.type = "button";
        deleteBtn.className = "absolute top-4 right-4 bg-red-600 hover:bg-red-700 text-white w-10 h-10 rounded-full flex items-center justify-center shadow-lg transition-transform hover:scale-110 active:scale-95 z-30";
        deleteBtn.innerHTML = `<span class="material-symbols-outlined text-lg">delete</span>`;
        deleteBtn.title = "Eliminar imagen";
        
        deleteBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          deleteImage(img.id);
        });

        card.appendChild(deleteBtn);
        // Border highlight to show we are editing
        card.classList.add('border-2', 'border-primary/40');
      }

      galleryGrid.appendChild(card);
    });
  }

  // Delete image function
  function deleteImage(id) {
    if (confirm('¿Estás seguro de que deseas eliminar esta imagen de la galería?')) {
      images = images.filter(img => img.id !== id);
      localStorage.setItem('cartacuba_gallery_images', JSON.stringify(images));
      renderGallery();
    }
  }

  // Toggle Edit Mode panel
  editToggle.addEventListener('change', () => {
    if (editToggle.checked) {
      addImagePanel.classList.replace('hidden', 'block');
    } else {
      addImagePanel.classList.replace('block', 'hidden');
    }
    renderGallery();
  });

  // Cancel button resets form and hides panel
  cancelAddBtn.addEventListener('click', () => {
    editToggle.checked = false;
    addImagePanel.classList.replace('block', 'hidden');
    addImageForm.reset();
    renderGallery();
  });

  // Form submission logic
  addImageForm.addEventListener('submit', (e) => {
    e.preventDefault();
    
    const caption = document.getElementById('img-caption').value.trim();
    const id = 'img-' + Date.now();

    if (currentInputMode === 'url') {
      const url = document.getElementById('img-url').value.trim();
      if (!url) {
        alert('Por favor introduce una dirección URL válida.');
        return;
      }
      
      // Save item
      images.push({ id, url, caption });
      localStorage.setItem('cartacuba_gallery_images', JSON.stringify(images));
      
      // Reset & Render
      addImageForm.reset();
      renderGallery();
    } else {
      const fileInput = document.getElementById('img-file');
      const file = fileInput.files[0];
      
      if (!file) {
        alert('Por favor selecciona un archivo de imagen local.');
        return;
      }

      // Read file as Base64 dataURL
      const reader = new FileReader();
      reader.onload = function(event) {
        const base64Url = event.target.result;
        
        // Save item
        images.push({ id, url: base64Url, caption });
        localStorage.setItem('cartacuba_gallery_images', JSON.stringify(images));
        
        // Reset & Render
        addImageForm.reset();
        renderGallery();
      };
      
      reader.readAsDataURL(file);
    }
  });

  // Initialize
  renderGallery();
</script>
