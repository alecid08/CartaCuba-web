---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
---

<BaseLayout title="Cultura y Tradiciones | CartaCuba" activePage="culture" bodyClass="bg-background text-on-background font-body-md textured-bg">
  <!-- Hero Section -->
  <HeroSection
    bgImage="https://lh3.googleusercontent.com/aida-public/AB6AXuDaJNzvvDBl5O8gkiYyAkiS1cuaHmV5_SDTBAO7KwxYQwaAG9xqFUtHy4Lt0YU-Gfp0m41af6_A-YokKYuyxyHQj2PBMPLxMXFJpd9qmlMwmI3MLjSdFV9x6y-c4O2IPCRWY-McZFcW_9ADPtFY2zW6YItvGHM5_khMNSKBq1mBrCBbOJoBDJKfjTNSDINyJvenanl2bY1j93h0m4xb9PbkJXTZlQSoNknjBpMKCn0zSNFCjMDs5Y5TE7YALCnucNHuU-e4MuSFspI"
    badgeText="La Identidad Agramontina"
    badgeClass="inline-block bg-primary text-on-primary px-4 py-1 rounded-full font-label-md text-label-md mb-6"
    title="Ecos Auténticos de <br/><span class='text-primary italic'>Camagüey</span>"
    description="Experimenta el alma de una ciudad forjada en arcilla y leyenda. Desde las calles laberínticas hasta el pulso rítmico del San Juan, descubre las tradiciones que definen el corazón agramontino."
    heightClass="h-[819px]"
  >
    <button class="bg-primary text-on-primary px-8 py-4 rounded-full font-label-md text-label-md flex items-center gap-2 hover:scale-105 transition-transform">
      Explorar Tradiciones <span class="material-symbols-outlined">arrow_downward</span>
    </button>
  </HeroSection>

  <main class="relative">
    <!-- Bento Tradition Grid -->
    <section class="py-24 px-margin-desktop max-w-container-max mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
        <!-- Large Feature: Tinajones -->
        <div class="md:col-span-8 bg-surface-container rounded-3xl overflow-hidden group border border-outline-variant/30 flex flex-col md:flex-row h-full">
          <div class="md:w-1/2 overflow-hidden">
            <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="Clay tinajones in a courtyard" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB4CGZIsFgj5ptXEY0lJL24TwAkiwFrvwwKBoXx2zXM2Zz6FF1YbzNV3AERkk2DLRPd8rvhGHvnLyTluS86zY-QJgbPt9jSOR71RYDyqOjOawnTM4vrIIfXIlAYOXhDa-7YU81AlEXAs3NOsof_EG0H3Ne2KULYS2hCv8oHdLTD3xE7rnoOklIr95gx5vikjjwLXO7RrbcYwLT3k1mdHzErHUf514zyW5kCBKbz53CjZinrN5n_xWZQrSkrSQIZ1JHVKQI3b1yNUNA">
          </div>
          <div class="md:w-1/2 p-10 flex flex-col justify-center">
            <h3 class="font-headline-md text-headline-md mb-4 text-primary font-semibold">La Leyenda del Tinajón</h3>
            <p class="font-body-md text-body-md text-on-surface-variant mb-6 italic border-l-2 border-primary pl-4">"El que toma agua del tinajón, siempre regresa a Camagüey."</p>
            <p class="font-body-md text-body-md text-on-surface-variant mb-6">Estas icónicas vasijas de barro son los testigos silenciosos de nuestra historia. Originalmente diseñadas para almacenar agua de lluvia en las secas sabanas, se han convertido en el símbolo supremo de la identidad regional.</p>
            <a class="text-primary font-label-md flex items-center gap-2 group-hover:gap-4 transition-all" href="#">Aprende Artes Cerámicas <span class="material-symbols-outlined">arrow_forward</span></a>
          </div>
        </div>

        <!-- Vertical Card: San Juan Camagüeyano -->
        <div class="md:col-span-4 bg-primary-container text-on-primary-container rounded-3xl p-10 relative overflow-hidden group border border-primary-fixed/20">
          <div class="relative z-10 h-full flex flex-col">
            <span class="material-symbols-outlined text-5xl mb-6 text-primary-fixed">celebration</span>
            <h3 class="font-headline-sm text-headline-sm mb-4 font-semibold">San Juan Camagüeyano</h3>
            <p class="font-body-md text-body-md opacity-90 mb-8">El carnaval más antiguo y vibrante de Cuba. Una explosión rítmica de 'congas', 'comparsas' y el ritual de la quema del 'San Juan'.</p>
            <div class="mt-auto">
              <img class="w-full aspect-video object-cover rounded-xl mb-4 grayscale group-hover:grayscale-0 transition-all duration-500" alt="San Juan carnival dancers" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCYkf7WyKrLoAo84V_pSeSTFUM8svSMqWh4X2yMBkk4fp33no_SxlSWAKSyJ1VdB2V0wkorpFBZbvqF7VbS_qUfFVbMbpiIX61qCmNDV-ynzPoEDSPnhMEbfgK5teX4w5KA7oggkLRA76HInicTpAbvJu5B4P74fog-QTb1xnIxG4nfFBob2DUMpAapOfigeC2Z_t25hqoS-fbZbL61R-ABBZzd0pvoLt6OAR3W5MGOE0NzYZHzxrbJd1Zey07Rf1C8_ZMBcE8P1Bs">
              <p class="font-label-md uppercase tracking-widest text-xs opacity-80">Cada 24 - 29 de junio</p>
            </div>
          </div>
          <div class="absolute -right-10 -bottom-10 opacity-10 group-hover:rotate-12 transition-transform duration-1000">
            <span class="material-symbols-outlined text-[200px]">festival</span>
          </div>
        </div>

        <!-- Asymmetric Card: Native Crafts -->
        <div class="md:col-span-6 bg-surface-container-high rounded-3xl p-8 flex gap-8 items-center border border-outline-variant/20">
          <div class="w-1/3">
            <div class="organic-shape bg-primary/10 overflow-hidden aspect-square">
              <img class="w-full h-full object-cover" alt="Artisan weaving" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCa3JeHwXcw11lEsFE6Zx1CKz6PBudf3NZHvt02FAE_7dMfI3rxfOIEff04K4moXph3sX2UKgaUoD3uNXyGperCWpYHoq1R4X58ljTOhrePdDI9RnC2TBixIoIhtciu12-2fX1uB55d4a6y4TwzbxVxhQyw_kEmJPEp6vyy0V98AbNGk8_JR3-h34grFYJ7gcAx-XKvIHtKKejkFVCFG2gUWhEUPE7E5hW9DlADqNyOq74yCsLyhYYDtX0fbueqxemzb36TTB-YH9Q">
            </div>
          </div>
          <div class="w-2/3">
            <h4 class="font-headline-sm text-headline-sm text-on-surface mb-2 font-semibold">Artesanías Nativas</h4>
            <p class="font-body-md text-body-md text-on-surface-variant">Talabartería intrincada, tejido de hojas de palma y el delicado arte del 'tejido de punto'. Cada pieza lleva el alma del artesano agramontino.</p>
          </div>
        </div>

        <!-- Stats/Highlights Card -->
        <div class="md:col-span-6 grid grid-cols-2 gap-4">
          <div class="bg-primary text-on-primary rounded-3xl p-6 flex flex-col justify-center items-center text-center">
            <span class="font-display-lg text-display-lg leading-none font-bold">1514</span>
            <p class="font-label-md text-label-md mt-2">Año de Fundación</p>
          </div>
          <div class="bg-surface-container-highest rounded-3xl p-6 flex flex-col justify-center items-center text-center border border-outline-variant/30">
            <span class="font-display-lg text-display-lg text-primary leading-none font-bold">8</span>
            <p class="font-label-md text-label-md text-on-surface-variant mt-2">Plazas Patrimoniales</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Immersive Quote Section -->
    <section class="relative py-24 bg-inverse-surface text-inverse-on-surface overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-full opacity-10">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-primary to-transparent"></div>
      </div>
      <div class="relative z-10 px-margin-desktop max-w-container-max mx-auto text-center">
        <span class="material-symbols-outlined text-6xl text-primary mb-8" style="font-variation-settings: 'FILL' 1;">format_quote</span>
        <blockquote class="font-headline-md text-headline-md max-w-3xl mx-auto mb-8 italic font-semibold">
          "Para entender a Cuba, primero se deben escuchar los susurros de los callejones serpenteantes de Camagüey y la profunda resonancia de su arcilla."
        </blockquote>
        <cite class="font-label-md text-label-md uppercase tracking-widest text-primary font-bold">— Archivos de Historiadores Locales</cite>
      </div>
    </section>

    <!-- Heritage Mapping Section -->
    <section class="py-24 px-margin-desktop max-w-container-max mx-auto">
      <div class="flex flex-col md:flex-row gap-16 items-center">
        <div class="md:w-1/2">
          <h2 class="font-display-lg text-display-lg text-on-background mb-6 font-bold">La Ciudad Laberinto</h2>
          <p class="font-body-lg text-body-lg text-on-surface-variant mb-8">A diferencia de cualquier otra ciudad colonial española, Camagüey fue construida como un laberinto de calles irregulares y callejones sin salida para confundir a piratas e invasores. Hoy en día, sirve como un museo al aire libre de arquitectura y comunidad.</p>
          <ul class="space-y-6">
            <li class="flex gap-4">
              <span class="material-symbols-outlined text-primary">location_on</span>
              <div>
                <h5 class="font-body-lg font-bold text-on-surface">Plaza de San Juan de Dios</h5>
                <p class="text-on-surface-variant font-body-md">El conjunto arquitectónico más completo de la ciudad, perfectamente conservado desde el siglo XVIII.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="material-symbols-outlined text-primary">location_on</span>
              <div>
                <h5 class="font-body-lg font-bold text-on-surface">Plaza del Carmen</h5>
                <p class="text-on-surface-variant font-body-md">Hogar de esculturas de tamaño natural de los lugareños en su vida cotidiana, creadas por Martha Jiménez.</p>
              </div>
            </li>
          </ul>
        </div>
        <div class="md:w-1/2 relative">
          <div class="bg-surface-container p-4 rounded-[2rem] shadow-xl rotate-2">
            <img class="rounded-[1.5rem] w-full aspect-square object-cover" alt="Aerial view of Camagüey historic center" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCptiss7N2AWTgPothLayC95TWVYgsnVHXtumaiT0yOM1a_lxe0So5KvhhM11Jdmfvl2oYbSychr-qBsAEVb9KeUOywtYDBTJf30k8nmrOM3AeUM2mw1XvK3xq5zBwY5SsQUjyssKh79pcuXfGAX4tJ4T6W7vN8aRX1JlCi59rN95XtO-zkgiUqryu-FHg-Hm6JLMF_1ynSiBIiuRIWjWlENsj22dQ--nleiih-vQjSwyq4NhV29zK3NTBqUZ76kGARpim7-Mz9lpE">
          </div>
          <div class="absolute -bottom-6 -left-6 bg-primary-container text-on-primary-container p-8 rounded-2xl shadow-lg -rotate-3 hidden lg:block border border-primary-fixed/20">
            <p class="font-headline-sm font-semibold">UNESCO</p>
            <p class="font-label-md uppercase tracking-wider opacity-90 font-bold">Patrimonio de la Humanidad</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-24 px-margin-desktop">
      <div class="max-w-container-max mx-auto bg-primary rounded-[3rem] p-12 md:p-20 text-center relative overflow-hidden">
        <div class="absolute inset-0 opacity-20 pointer-events-none">
          <div class="w-full h-full border-[30px] border-on-primary/10 rounded-full scale-150 animate-pulse"></div>
        </div>
        <div class="relative z-10">
          <h2 class="font-display-lg text-display-lg text-on-primary mb-6 font-bold">Sé Parte de la Leyenda</h2>
          <p class="font-body-lg text-on-primary/90 max-w-2xl mx-auto mb-10">Únete a nuestras caminatas culturales guiadas y talleres de artesanos para experimentar de primera mano la verdadera identidad agramontina.</p>
          <div class="flex flex-wrap justify-center gap-4">
            <button class="bg-on-primary text-primary px-10 py-4 rounded-full font-label-md text-label-md hover:bg-on-primary-container transition-colors shadow-md active:scale-95">Reservar una Caminata Patrimonial</button>
            <button class="border-2 border-on-primary text-on-primary px-10 py-4 rounded-full font-label-md text-label-md hover:bg-on-primary/10 transition-colors active:scale-95">Descargar Guía Cultural</button>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
