---
interface Props {
  activePage?: 'home' | 'tours' | 'destino' | 'nosotros';
}

const { activePage } = Astro.props;

const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith('/') ? base : `${base}/`;

const links = [
  { name: 'Inicio', href: cleanBase, id: 'home' },
  { name: 'Tours', href: `${cleanBase}tours/`, id: 'tours' },
  { name: 'Destino', href: `${cleanBase}destino/`, id: 'destino' },
  { name: 'Nosotros', href: `${cleanBase}nosotros/`, id: 'nosotros' }
];
---

<header class="fixed top-0 w-full z-50 bg-background/80 dark:bg-background/80 backdrop-blur-md border-b border-outline-variant/30 transition-all duration-300 ease-in-out h-20" id="main-nav">
  <div class="flex justify-between items-center h-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto w-full">
    <a class="flex items-center gap-3 font-headline-sm text-headline-sm text-primary dark:text-inverse-primary tracking-tight transition-transform hover:scale-102" href={cleanBase}>
      <!-- Custom SVG Logo representing the Cartacuba bird and conservation leaf -->
      <svg class="w-10 h-10 drop-shadow-sm" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Bird wing/leaf shape in emerald green -->
        <path d="M15 80C30 80 65 65 80 40C90 25 85 5 70 10C50 15 35 40 30 55C25 45 20 30 10 25C0 20 0 40 5 55C7 63 7 73 15 80Z" fill="#006b34"/>
        <!-- Bird red throat accent -->
        <path d="M70 10C63 13 57 20 55 27C59 29 65 27 70 23C72 19 72 13 70 10Z" fill="#bb0017"/>
        <!-- Bird eye in white -->
        <circle cx="73" cy="17" r="2.5" fill="white"/>
      </svg>
      <span class="font-bold font-headline-sm">CartaCuba</span>
    </a>
    
    <nav class="hidden md:flex items-center gap-8">
      {links.map((link) => {
        const isActive = activePage === link.id;
        return (
          <a 
            class={`font-body-md text-body-md transition-colors relative py-1 ${
              isActive 
                ? 'text-primary dark:text-primary-fixed-dim font-semibold border-b-2 border-primary dark:border-primary-fixed-dim' 
                : 'text-on-surface-variant dark:text-surface-variant hover:text-primary dark:hover:text-primary-fixed-dim'
            }`} 
            href={link.href}
          >
            {link.name}
          </a>
        );
      })}
    </nav>
    
    <div class="flex items-center gap-4">
      <!-- Call to Action - Highlighted -->
      <a 
        href={`${cleanBase}tours/`}
        class="bg-primary hover:bg-primary-container text-white dark:bg-primary dark:hover:bg-primary-container px-6 py-3 rounded-full font-label-md text-label-md transition-all shadow-md hover:shadow-lg active:scale-95 flex items-center gap-2 border border-primary/20 hover:scale-105"
      >
        <span class="material-symbols-outlined text-[20px]">explore</span>
        <span>Reservar Ahora</span>
      </a>
      
      <!-- Mobile Menu Toggle -->
      <button class="md:hidden material-symbols-outlined p-2 text-on-surface-variant" id="menu-toggle">
        menu
      </button>
    </div>
  </div>

  <!-- Mobile Dropdown Menu -->
  <div class="hidden md:hidden absolute top-20 left-0 w-full bg-background border-b border-outline-variant/30 flex flex-col p-6 gap-4 z-40 shadow-lg animate-fade-in" id="mobile-menu">
    {links.map((link) => {
      const isActive = activePage === link.id;
      return (
        <a 
          class={`font-body-md text-body-md py-2 ${
            isActive 
              ? 'text-primary font-semibold border-l-4 border-primary pl-2' 
              : 'text-on-surface-variant pl-2'
          }`} 
          href={link.href}
        >
          {link.name}
        </a>
      );
    })}
  </div>
</header>

<script>
  // Simple scroll interaction for header
  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    if (nav) {
      if (window.scrollY > 50) {
        nav.classList.add('shadow-md', 'h-16');
        nav.classList.remove('h-20');
      } else {
        nav.classList.remove('shadow-md', 'h-16');
        nav.classList.add('h-20');
      }
    }
  });

  // Mobile menu toggle
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  if (menuToggle && mobileMenu) {
    menuToggle.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>
