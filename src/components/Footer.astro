---
---
<footer class="w-full mt-auto bg-surface-container-highest dark:bg-inverse-surface border-t border-outline-variant/50">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-gutter px-margin-mobile md:px-margin-desktop py-12 max-w-container-max mx-auto text-on-surface dark:text-inverse-on-surface">
    <!-- Brand / About Column -->
    <div class="space-y-4">
      <div class="font-headline-sm text-headline-sm text-primary dark:text-inverse-primary">CartaCuba</div>
      <p class="text-on-surface-variant dark:text-surface-variant font-body-md text-body-md pr-4">
        Pioneering authentic ecotourism in central Cuba. Preserving the heritage and vibrant biodiversity of Camagüey through immersive, sustainable travel.
      </p>
      <div class="flex gap-4">
        <span class="material-symbols-outlined text-primary hover:text-secondary cursor-pointer transition-colors" title="Facebook">face_nod</span>
        <span class="material-symbols-outlined text-primary hover:text-secondary cursor-pointer transition-colors" title="Instagram">photo_camera</span>
        <span class="material-symbols-outlined text-primary hover:text-secondary cursor-pointer transition-colors" title="Share">share</span>
      </div>
    </div>

    <!-- Navigation Column -->
    <div class="space-y-4">
      <h5 class="font-bold text-on-surface dark:text-inverse-on-surface uppercase tracking-wider text-sm">Explore</h5>
      <ul class="space-y-2 font-body-md text-body-md">
        <li><a class="text-on-surface-variant dark:text-surface-variant hover:text-secondary transition-colors" href="/nature">Nature Trails</a></li>
        <li><a class="text-on-surface-variant dark:text-surface-variant hover:text-secondary transition-colors" href="/heritage">Urban Heritage</a></li>
        <li><a class="text-on-surface-variant dark:text-surface-variant hover:text-secondary transition-colors" href="/estancias">Local Stays</a></li>
        <li><a class="text-on-surface-variant dark:text-surface-variant hover:text-secondary transition-colors" href="/culture">Culture & Traditions</a></li>
      </ul>
    </div>

    <!-- Categories / Info Column -->
    <div class="space-y-4">
      <h5 class="font-bold text-on-surface dark:text-inverse-on-surface uppercase tracking-wider text-sm">Destinations</h5>
      <ul class="space-y-2 font-body-md text-body-md">
        <li><a class="text-on-surface-variant dark:text-surface-variant hover:text-secondary transition-colors" href="#">Sierra de Cubitas</a></li>
        <li><a class="text-on-surface-variant dark:text-surface-variant hover:text-secondary transition-colors" href="#">Limones-Tuabaquey</a></li>
        <li><a class="text-on-surface-variant dark:text-surface-variant hover:text-secondary transition-colors" href="#">Plaza de San Juan</a></li>
        <li><a class="text-on-surface-variant dark:text-surface-variant hover:text-secondary transition-colors" href="#">Colonial Patios</a></li>
      </ul>
    </div>

    <!-- Contact / Newsletter Column -->
    <div class="bg-primary/5 dark:bg-black/20 p-6 rounded-xl border border-primary/10">
      <h5 class="font-bold mb-3 text-on-surface dark:text-inverse-on-surface">Stay Inspired</h5>
      <p class="text-on-surface-variant dark:text-surface-variant text-[14px] mb-4">Receive monthly updates on bird sightings and festival dates.</p>
      <div class="flex flex-col gap-2">
        <input 
          class="bg-background border border-outline-variant rounded-lg px-4 py-2 text-on-surface placeholder-on-surface-variant/60 focus:ring-primary focus:border-primary w-full" 
          placeholder="Your Email" 
          type="email"
        />
        <button class="bg-primary text-white py-2 rounded-lg font-label-md text-label-md hover:bg-primary-container transition-colors w-full">
          Subscribe
        </button>
      </div>
    </div>
  </div>

  <!-- Copyright Bar -->
  <div class="border-t border-outline-variant/30 py-6 text-center">
    <p class="text-on-surface-variant dark:text-surface-variant text-[12px] font-body-md">
      © 2024 CartaCuba. Preserving the heritage of Camagüey.
    </p>
  </div>
</footer>
