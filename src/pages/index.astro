---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import TourCarousel from '../components/TourCarousel.astro';
import EssenceSlider from '../components/EssenceSlider.astro';

const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith('/') ? base : `${base}/`;

const travelerReviews = [
  {
    name: "María González",
    initial: "M",
    country: "España 🇪🇸",
    comment: "Una experiencia completamente diferente a todo lo que habíamos vivido antes. Alejandro nos llevó a rincones de Camagüey que nunca hubiéramos encontrado solos. La conexión con los artistas locales y la historia contada desde adentro fue simplemente inolvidable."
  },
  {
    name: "Carlos Mendoza",
    initial: "C",
    country: "México 🇲🇽",
    comment: "Viajamos en familia y fue la mejor decisión del viaje. El trato fue cercano desde el primer mensaje. Nos adaptaron absolutamente todo a nuestro ritmo y los niños quedaron fascinados. Cuba auténtica, sin filtros y sin artificios."
  },
  {
    name: "Lucía Fernández",
    initial: "L",
    country: "Argentina 🇦🇷",
    comment: "Pensé que ya conocía Cuba, pero CartaCuba me mostró que no había visto nada. La naturaleza, la gastronomía, el arte... todo integrado en una experiencia que se siente viva. Ya estoy planeando volver para los otros tours."
  }
];
---

<BaseLayout title="CartaCuba | Ecoturismo y Patrimonio en Camagüey" activePage="home">
  <!-- Hero Carousel (Inspirado en Intrepid Travel, sin buscador) -->
  <HeroCarousel />

  <main class="relative bg-background">
    <section class="py-20 border-b border-outline-variant/20" style="background: linear-gradient(15deg, rgba(31, 61, 43, 0.08), rgba(62, 107, 72, 0.08));">
      <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto mb-10 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div class="max-w-2xl">
          <span class="text-primary font-label-md uppercase tracking-wider block mb-2">Viajes que Inspiran</span>
          <h2 class="font-headline-md text-headline-md font-bold text-on-surface">Tours y Ofertas Disponibles</h2>
          <p class="text-on-surface-variant font-body-md mt-2">
            Pequeños grupos, grandes vivencias. Elige la experiencia que mejor se adapte a tu estilo de descubrimiento.
          </p>
        </div>
        <a 
          href={`${cleanBase}tours/`} 
          class="inline-flex items-center gap-2 text-primary font-label-md hover:underline group self-start md:self-end"
        >
          <span>Ver todos los tours</span>
          <span class="material-symbols-outlined transition-transform group-hover:translate-x-1">east</span>
        </a>
      </div>
      
      <!-- Tour Carousel Component -->
      <TourCarousel />
    </section>

    <!-- Destination Essence Section (Naturaleza, Patrimonio, Cultura - Basado en la Esencia original) -->
    <section class="py-24 bg-surface-container-low relative border-b border-outline-variant/20">
      <div class="grainy-overlay absolute inset-0 pointer-events-none opacity-50"></div>
      <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
        <div class="text-center max-w-3xl mx-auto mb-12">
          <span class="text-primary font-label-md uppercase tracking-widest block mb-2">El Espíritu de la Tierra</span>
          <h2 class="font-headline-md text-headline-md text-on-surface font-bold">Arraigados en el Patrimonio, Inspirados en la Naturaleza</h2>
          <p class="text-[#1F3D2B] dark:text-surface-variant font-body-lg mt-3 font-semibold">
            CartaCuba es más que un recorrido turístico; es un compromiso activo con la conservación y la cultura local.
          </p>
        </div>
        
        <EssenceSlider />
      </div>
    </section>

    <!-- Testimonials / Reviews Section -->
    <section class="py-24 bg-[#E8D8B7] border-b border-outline-variant/20 relative">
      <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="font-display-playfair text-[#1F3D2B] text-3xl sm:text-4xl md:text-5xl font-bold leading-tight">
            Lo que dicen nuestros viajeros
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {travelerReviews.map((review) => (
            <div class="bg-white p-6 sm:p-8 rounded-2xl border border-[#3E6B48]/30 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md flex flex-col justify-between h-full">
              <div>
                <!-- User Profile Header -->
                <div class="flex items-center gap-4 mb-4">
                  <!-- Circular avatar -->
                  <div class="w-12 h-12 rounded-full bg-[#C47A2C] text-white flex items-center justify-center font-bold text-lg shrink-0 shadow-sm select-none">
                    {review.initial}
                  </div>
                  <div>
                    <h4 class="font-bold text-[#1F3D2B] font-body-lg text-base leading-tight">
                      {review.name}
                    </h4>
                    <p class="text-xs text-on-surface-variant/80 font-body-md mt-0.5">
                      {review.country}
                    </p>
                  </div>
                </div>

                <!-- Star Rating -->
                <div class="flex text-[#C47A2C] text-lg select-none mb-4" aria-label="5 de 5 estrellas">
                  <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
                </div>

                <!-- Comment text -->
                <p class="text-on-surface-variant dark:text-on-surface-variant font-body-md text-sm sm:text-base leading-relaxed italic">
                  "{review.comment}"
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Dynamic Visual Section (Local Guide Quote) -->
    <section class="h-[550px] relative overflow-hidden flex items-center justify-center">
      <div class="absolute inset-0 bg-fixed bg-center bg-cover parallax-bg" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDLNVOsR1PVd7dzt3b6ZXxlzC0zTgYuR5utXqWceu2W1ws99Kkqjl0XYt782Xu1V5Prv2DpreUAK-ziymPj--vxtA0lj_uCsfAokNXOejp1Ob1WhmTtanSaYU3YMMexZOuvqcn8saRY5MLgavMiI3izcVaqEKG-c8g1PD8PMVDgVZAz0KypYAfpGpkEFs9GPAK7PtG9C0WPgzzbENVD1Ma9rahWP7q6_ADPH3On3j9O7eKbXOnE0Dt6QEKxQYZ7MsLnkMWyXOG9ozQ');">
        <div class="absolute inset-0 bg-primary/50 mix-blend-multiply"></div>
      </div>
      <div class="relative z-10 text-center text-white px-margin-mobile max-w-4xl mx-auto space-y-6">
        <span class="material-symbols-outlined text-5xl text-primary-fixed animate-bounce">format_quote</span>
        <blockquote>
          <p class="font-display-lg text-display-lg-mobile md:text-3xl lg:text-4xl italic font-semibold leading-relaxed">
            "Visitar Camagüey es entrar en un ritmo que no ha cambiado en siglos, donde la naturaleza y la piedra colonial viven en perfecta armonía."
          </p>
          <cite class="font-label-md text-label-md uppercase tracking-widest text-primary-fixed font-bold block mt-6">
            — Conservacionista y Guía Local
          </cite>
        </blockquote>
      </div>
    </section>
  </main>
</BaseLayout>

