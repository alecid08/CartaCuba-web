---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import TourCarousel from '../components/TourCarousel.astro';

const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith('/') ? base : `${base}/`;
---

<BaseLayout title="CartaCuba | Ecoturismo y Patrimonio en Camagüey" activePage="home">
  <!-- Hero Carousel (Inspirado en Intrepid Travel, sin buscador) -->
  <HeroCarousel />

  <main class="relative bg-background">
    <!-- Tours & Offers Section (Pequeñas tarjetas, al estilo Intrepid Travel) -->
    <section class="py-20 bg-background border-b border-outline-variant/20">
      <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto mb-10 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div class="max-w-2xl">
          <span class="text-primary font-label-md uppercase tracking-wider block mb-2">Viajes que Inspiran</span>
          <h2 class="font-headline-md text-headline-md font-bold text-on-surface">Tours y Ofertas Disponibles</h2>
          <p class="text-on-surface-variant font-body-md mt-2">
            Pequeños grupos, grandes vivencias. Elige la experiencia que mejor se adapte a tu estilo de descubrimiento.
          </p>
        </div>
        <a 
          href={`${cleanBase}tours/`} 
          class="inline-flex items-center gap-2 text-primary font-label-md hover:underline group self-start md:self-end"
        >
          <span>Ver todos los tours</span>
          <span class="material-symbols-outlined transition-transform group-hover:translate-x-1">east</span>
        </a>
      </div>
      
      <!-- Tour Carousel Component -->
      <TourCarousel />
    </section>

    <!-- Destination Essence Section (Naturaleza, Patrimonio, Cultura - Basado en la Esencia original) -->
    <section class="py-24 bg-surface-container-low relative border-b border-outline-variant/20">
      <div class="grainy-overlay absolute inset-0 pointer-events-none opacity-50"></div>
      <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto grid md:grid-cols-2 gap-16 items-center">
        <!-- Visuals Column -->
        <div class="relative">
          <div class="absolute -top-10 -left-10 w-40 h-40 bg-primary/10 rounded-full blur-3xl"></div>
          <img 
            alt="Patrimonio de Camagüey" 
            class="leaf-shape w-full h-[550px] object-cover border border-outline-variant/30 shadow-md" 
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDzJbCzSWWEURx_HC4cIVlOLmhNAk8vVuS3EpqqDykV2YH97cHzFqRfos930Yr4_5fTHI_LI6rQ4tckXZzkwQmmOgmQqIanBjMKTc6zLyH3F8Q4cyyReHWS5piDwd9rk5FAzX3zJ4I5daeFWCsNd9QmzKP9YRpb3CbOKFRML2Q7CoVXJAWRVH77YJ40p4ot4IDY0_sCUuL6cRIM9qwVbWMm2nTd8DiPTIKshHDufuThKxItDlJkmS4PV4IJ2VfCa4PEQ-Wti4XHY6w"
          />
          <div class="absolute -bottom-6 -right-6 bg-white dark:bg-inverse-surface p-6 rounded-xl shadow-lg border border-outline-variant/20 max-w-xs">
            <span class="text-secondary font-headline-sm text-headline-sm block mb-1">Más de 500 Años</span>
            <p class="text-on-surface-variant dark:text-surface-variant font-body-md text-sm italic">Preservando el legado de la alfarería tradicional y las leyendas urbanas coloniales.</p>
          </div>
        </div>

        <!-- Description Column -->
        <div class="space-y-8">
          <div class="space-y-4">
            <span class="text-primary font-label-md uppercase tracking-widest block">El Espíritu de la Tierra</span>
            <h2 class="font-headline-md text-headline-md text-on-surface font-bold">Arraigados en el Patrimonio, Inspirados en la Naturaleza</h2>
            <p class="text-on-surface-variant font-body-lg">
              CartaCuba es más que un recorrido turístico; es un compromiso activo con la conservación y la cultura local. Nuestra filosofía equilibra la pureza de la biosfera cubana con la digna historia arquitectónica de Camagüey, la ciudad de los tinajones.
            </p>
          </div>
          
          <ul class="space-y-6">
            <li class="flex items-start gap-4">
              <span class="material-symbols-outlined text-primary bg-primary/10 p-2.5 rounded-lg" style="font-variation-settings: 'FILL' 1;">eco</span>
              <div>
                <h4 class="font-bold text-on-surface">Ecoturismo Responsable</h4>
                <p class="text-on-surface-variant font-body-md">Senderos ecológicos diseñados de forma ética para no interferir en el hábitat natural del Cartacuba y otras especies protegidas.</p>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <span class="material-symbols-outlined text-primary bg-primary/10 p-2.5 rounded-lg" style="font-variation-settings: 'FILL' 1;">architecture</span>
              <div>
                <h4 class="font-bold text-on-surface">Inmersiones en la Tradición</h4>
                <p class="text-on-surface-variant font-body-md">Acceso de primera mano a talleres de artesanos, patios coloniales y rincones secretos ricos en leyendas agramontinas.</p>
              </div>
            </li>
          </ul>

          <div class="pt-4">
            <a 
              href={`${cleanBase}destino/`} 
              class="inline-flex items-center gap-2 bg-primary text-white hover:bg-primary-container px-6 py-3 rounded-full font-label-md transition-all shadow-sm"
            >
              <span>Explorar Camagüey</span>
              <span class="material-symbols-outlined text-lg">explore</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Dynamic Visual Section (Local Guide Quote) -->
    <section class="h-[550px] relative overflow-hidden flex items-center justify-center">
      <div class="absolute inset-0 bg-fixed bg-center bg-cover parallax-bg" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDLNVOsR1PVd7dzt3b6ZXxlzC0zTgYuR5utXqWceu2W1ws99Kkqjl0XYt782Xu1V5Prv2DpreUAK-ziymPj--vxtA0lj_uCsfAokNXOejp1Ob1WhmTtanSaYU3YMMexZOuvqcn8saRY5MLgavMiI3izcVaqEKG-c8g1PD8PMVDgVZAz0KypYAfpGpkEFs9GPAK7PtG9C0WPgzzbENVD1Ma9rahWP7q6_ADPH3On3j9O7eKbXOnE0Dt6QEKxQYZ7MsLnkMWyXOG9ozQ');">
        <div class="absolute inset-0 bg-primary/50 mix-blend-multiply"></div>
      </div>
      <div class="relative z-10 text-center text-white px-margin-mobile max-w-4xl mx-auto space-y-6">
        <span class="material-symbols-outlined text-5xl text-primary-fixed animate-bounce">format_quote</span>
        <blockquote>
          <p class="font-display-lg text-display-lg-mobile md:text-3xl lg:text-4xl italic font-semibold leading-relaxed">
            "Visitar Camagüey es entrar en un ritmo que no ha cambiado en siglos, donde la naturaleza y la piedra colonial viven en perfecta armonía."
          </p>
          <cite class="font-label-md text-label-md uppercase tracking-widest text-primary-fixed font-bold block mt-6">
            — Conservacionista y Guía Local
          </cite>
        </blockquote>
      </div>
    </section>
  </main>
</BaseLayout>

