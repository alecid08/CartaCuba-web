---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
---

<BaseLayout title="Estancias Auténticas | CartaCuba" activePage="estancias" bodyClass="bg-background text-on-background font-body-md texture-grain min-h-screen flex flex-col">
  <!-- Hero Section -->
  <HeroSection
    bgImage="https://lh3.googleusercontent.com/aida-public/AB6AXuDnlb4glw2CPTGZCUI-HOuLt92aOEaYRT_uFZB9Klw-loSnseHCPIXOghOOOZPGHeNn0RrdKfy1AEUBBaydvT2Ixg3lRQux-ZGXV91RQQ4sR9aLSx63eSRLfqxre_sl7ZOVL8-Re2IWwcOaaAZmwS2D_0azOl2L1GQ70FgdE9xqos4SMBjFi4ZZbnVuhvvWG1-KrhgWksTih7Q3z4W5dp3rWM_nuEVif4VVhNLYf1IiVG6ig2mN-iiBnLyc0KE7f3xesXtT2RRnd8M"
    badgeText="Estancias Auténticas"
    badgeClass="inline-block bg-primary/10 text-primary font-label-md px-4 py-1 rounded-full mb-6"
    title="Hospedaje en Camagüey — Nuestras recomendaciones"
    description="CartaCuba no gestiona alojamiento directamente. Pero sí nos aseguramos de que tu llegada a Camagüey sea perfecta desde el primer momento. Colaboramos con casas particulares seleccionadas, donde serás recibido como en casa y donde tus experiencias con nosotros comienzan antes del primer tour."
    heightClass="h-[614px] md:h-[716px]"
  />

  <main class="relative py-20">
    <section class="px-margin-desktop max-w-container-max mx-auto">
      <div class="mb-12">
        <h2 class="font-headline-md text-headline-md text-on-background mb-4 font-semibold">Alojamientos Recomendados</h2>
        <p class="font-body-lg text-on-surface-variant max-w-2xl">
          Nuestras opciones en Camagüey. Disfruta de la privacidad de una casa de renta particular (seleccionadas por su calidad) o la comodidad de nuestros hoteles y hostales recomendados.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
        <!-- Casa de Renta 1 -->
        <div class="bg-surface-container rounded-[2rem] overflow-hidden border border-outline-variant/30 flex flex-col hover:-translate-y-1 transition-transform duration-300">
          <div class="h-64 overflow-hidden relative">
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuDsSWkVOOypuBYarFpfYFpdQB6tpYW2l12hwUVPHASzcyRinF2J71is-6_00W7clUwFQyHTc7JLOSd99Nz8LiPvq2FwcPfyPNMQQGSf36Hc0ZwPVQ7XViFFgYcYrhz79hd0OuNKkv23JaO5qiOdrKcMfhwujVGWQbSC4B4kH3s-OXKC-Y4sMvpUxI37gj9-bCjoi4MKwq_-7PcPFvKPChwyfEYedE1DNdZRbIdcWLkQ-DbSoYBsS1zZ4fcZj1WaOZsNWFkiX94lhIY" alt="Casa de Renta en Camagüey" class="w-full h-full object-cover" />
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="font-headline-sm text-headline-sm font-semibold mb-2 text-on-surface">Casa de Renta Particular</h3>
            <p class="font-body-md text-on-surface-variant mb-4 flex-grow">
              <strong class="text-on-surface">Habitaciones:</strong> 2<br/>
              <strong class="text-on-surface">Precio:</strong> $25 USD/noche<br/>
              <strong class="text-on-surface">Servicios:</strong> Desayuno, aire acondicionado, baño privado, ubicación céntrica.
            </p>
            <a href="https://wa.me/5351383690?text=Hola%2C%20me%20gustar%C3%ADa%20informaci%C3%B3n%20sobre%20casas%20de%20renta%20en%20Camag%C3%BCey" target="_blank" rel="noopener noreferrer" class="w-full bg-[#25D366] text-white py-3 px-4 rounded-xl font-label-md font-semibold text-center hover:bg-[#20bd5a] transition-colors flex items-center justify-center gap-2 mt-auto">
              <span class="material-symbols-outlined text-sm">chat</span> Consultar disponibilidad
            </a>
          </div>
        </div>

        <!-- Casa de Renta 2 -->
        <div class="bg-surface-container rounded-[2rem] overflow-hidden border border-outline-variant/30 flex flex-col hover:-translate-y-1 transition-transform duration-300">
          <div class="h-64 overflow-hidden relative">
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuA0X8UILMIH4e9HzrxMUwHRaDDJ9ykgL2ZDin5ruDdtaFV0fRs45uugCn4ZXdMzd40bWhRhgrlduOf9A2TsAgXMGBIg_QtdGxKJnUXmXcLXGZpDW7DaqHMLMUGhxmYAyErR9CaXZtG38l3_k2udT8qpYhKt6cDlomYS9b5p9v8Z-5jIFGR4lP1KJYgwhorwivqscHDObv1X95Z9xSRnMUfA6bzBKyUk_Rwez2pMhRNlgKrlNHBuTVcdTP1GiVnvWxGi2F0EH4fJWmY" alt="Casa de Renta Colonial" class="w-full h-full object-cover" />
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="font-headline-sm text-headline-sm font-semibold mb-2 text-on-surface">Casa de Renta Colonial</h3>
            <p class="font-body-md text-on-surface-variant mb-4 flex-grow">
              <strong class="text-on-surface">Habitaciones:</strong> 3<br/>
              <strong class="text-on-surface">Precio:</strong> $35 USD/noche<br/>
              <strong class="text-on-surface">Servicios:</strong> Patio colonial, desayuno, aire acondicionado, cenas tradicionales.
            </p>
            <a href="https://wa.me/5351383690?text=Hola%2C%20me%20gustar%C3%ADa%20informaci%C3%B3n%20sobre%20casas%20de%20renta%20en%20Camag%C3%BCey" target="_blank" rel="noopener noreferrer" class="w-full bg-[#25D366] text-white py-3 px-4 rounded-xl font-label-md font-semibold text-center hover:bg-[#20bd5a] transition-colors flex items-center justify-center gap-2 mt-auto">
              <span class="material-symbols-outlined text-sm">chat</span> Consultar disponibilidad
            </a>
          </div>
        </div>

        <!-- Casa de Renta 3 -->
        <div class="bg-surface-container rounded-[2rem] overflow-hidden border border-outline-variant/30 flex flex-col hover:-translate-y-1 transition-transform duration-300">
          <div class="h-64 overflow-hidden relative">
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuBIFnm245DOyNWCckQ3Z2d5_HDpxqbT0ywHadIkq4QwajKw6QdyXJCMa0644MiRYr0gmil33HzIc5xi0f3A6o7a_Ol9EzLZA9X9fZrEl7H026_-lUysmq_O9HF0gleXMczaGp0hWFslsYwHM6GYQrK_xRSdfXHLHKnmv0G-XGCy1M4XmgE7O1hj_SVyIdXPU0b9wCQ0MxHXD7AXedyXUCDG7vfyR2Modpk2xoAhYp6CeKsW8aAp8Mg5sW6bLTeYQwuECG0dqMAg4Uk" alt="Casa de Renta Económica" class="w-full h-full object-cover" />
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="font-headline-sm text-headline-sm font-semibold mb-2 text-on-surface">Casa de Renta Estándar</h3>
            <p class="font-body-md text-on-surface-variant mb-4 flex-grow">
              <strong class="text-on-surface">Habitaciones:</strong> 1<br/>
              <strong class="text-on-surface">Precio:</strong> $20 USD/noche<br/>
              <strong class="text-on-surface">Servicios:</strong> Terraza, céntrica, atención personalizada, agua caliente.
            </p>
            <a href="https://wa.me/5351383690?text=Hola%2C%20me%20gustar%C3%ADa%20informaci%C3%B3n%20sobre%20casas%20de%20renta%20en%20Camag%C3%BCey" target="_blank" rel="noopener noreferrer" class="w-full bg-[#25D366] text-white py-3 px-4 rounded-xl font-label-md font-semibold text-center hover:bg-[#20bd5a] transition-colors flex items-center justify-center gap-2 mt-auto">
              <span class="material-symbols-outlined text-sm">chat</span> Consultar disponibilidad
            </a>
          </div>
        </div>

        <!-- Hotel E Camino de Hierro -->
        <div class="bg-surface-container rounded-[2rem] overflow-hidden border border-outline-variant/30 flex flex-col hover:-translate-y-1 transition-transform duration-300">
          <div class="h-64 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Hotel E Camino de Hierro" class="w-full h-full object-cover" />
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="font-headline-sm text-headline-sm font-semibold mb-2 text-on-surface">Hotel E Camino de Hierro</h3>
            <p class="font-body-md text-on-surface-variant mb-4 flex-grow">Ubicado en la Plaza de la Soledad, destaca por su arquitectura colonial. Habitaciones íntimas, bar y excelente restaurante.</p>
            <a href="https://wa.me/5351383690?text=Hola%2C%20me%20gustar%C3%ADa%20informaci%C3%B3n%20sobre%20el%20Hotel%20Camino%20de%20Hierro" target="_blank" rel="noopener noreferrer" class="w-full bg-[#25D366] text-white py-3 px-4 rounded-xl font-label-md font-semibold text-center hover:bg-[#20bd5a] transition-colors flex items-center justify-center gap-2 mt-auto">
              <span class="material-symbols-outlined text-sm">chat</span> Consultar disponibilidad
            </a>
          </div>
        </div>

        <!-- Hotel E La Avellaneda -->
        <div class="bg-surface-container rounded-[2rem] overflow-hidden border border-outline-variant/30 flex flex-col hover:-translate-y-1 transition-transform duration-300">
          <div class="h-64 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Hotel E La Avellaneda" class="w-full h-full object-cover" />
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="font-headline-sm text-headline-sm font-semibold mb-2 text-on-surface">Hotel E La Avellaneda</h3>
            <p class="font-body-md text-on-surface-variant mb-4 flex-grow">Ubicación céntrica con buen servicio, patio interior acogedor, desayuno incluido y un ambiente muy tranquilo.</p>
            <a href="https://wa.me/5351383690?text=Hola%2C%20me%20gustar%C3%ADa%20informaci%C3%B3n%20sobre%20el%20Hotel%20La%20Avellaneda" target="_blank" rel="noopener noreferrer" class="w-full bg-[#25D366] text-white py-3 px-4 rounded-xl font-label-md font-semibold text-center hover:bg-[#20bd5a] transition-colors flex items-center justify-center gap-2 mt-auto">
              <span class="material-symbols-outlined text-sm">chat</span> Consultar disponibilidad
            </a>
          </div>
        </div>

        <!-- Gran Hotel -->
        <div class="bg-surface-container rounded-[2rem] overflow-hidden border border-outline-variant/30 flex flex-col hover:-translate-y-1 transition-transform duration-300">
          <div class="h-64 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1551882547-ff40c0d13936?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Gran Hotel Camagüey" class="w-full h-full object-cover" />
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="font-headline-sm text-headline-sm font-semibold mb-2 text-on-surface">Gran Hotel</h3>
            <p class="font-body-md text-on-surface-variant mb-4 flex-grow">Una opción clásica y espaciosa en el centro de la ciudad. Cuenta con piscina, restaurante y vistas panorámicas.</p>
            <a href="https://wa.me/5351383690?text=Hola%2C%20me%20gustar%C3%ADa%20informaci%C3%B3n%20sobre%20el%20Gran%20Hotel" target="_blank" rel="noopener noreferrer" class="w-full bg-[#25D366] text-white py-3 px-4 rounded-xl font-label-md font-semibold text-center hover:bg-[#20bd5a] transition-colors flex items-center justify-center gap-2 mt-auto">
              <span class="material-symbols-outlined text-sm">chat</span> Consultar disponibilidad
            </a>
          </div>
        </div>
      </div>

      <div class="mt-16 bg-surface-container-low p-8 md:p-12 rounded-[2.5rem] border border-outline-variant/30 text-center max-w-3xl mx-auto shadow-sm">
        <span class="material-symbols-outlined text-primary text-4xl mb-4">info</span>
        <p class="font-body-lg text-on-surface-variant leading-relaxed">
          Todas nuestras casas colaboradoras ofrecen desayuno incluido y atención en español. Las coordinamos directamente para que tu llegada a Camagüey sea perfecta.
          <br/><br/>
          <span class="font-semibold text-on-surface">¿Tienes alguna preferencia especial? Escríbenos.</span>
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
