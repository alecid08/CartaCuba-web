---
const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith('/') ? base : `${base}/`;
---
<footer class="w-full mt-auto bg-surface-container-highest dark:bg-inverse-surface border-t border-outline-variant/50">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter px-margin-mobile md:px-margin-desktop py-12 max-w-container-max mx-auto text-on-surface dark:text-inverse-on-surface">
    <!-- Brand / About Column -->
    <div class="space-y-4">
      <div class="font-headline-sm text-headline-sm text-primary dark:text-inverse-primary">CartaCuba</div>
      <p class="text-on-surface-variant dark:text-surface-variant font-body-md text-body-md pr-4">
        Descubre Cuba desde dentro. Pioneros del ecoturismo auténtico en el centro de Cuba. Preservando el patrimonio y la vibrante biodiversidad de Camagüey a través de viajes inmersivos y sostenibles.
      </p>
      <div class="flex gap-4">
        <a 
          href="https://facebook.com" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="flex items-center justify-center w-10 h-10 rounded-full bg-[#1F3D2B] text-white hover:bg-[#C47A2C] transition-all duration-200 transform hover:scale-[1.15] cursor-pointer shadow-sm"
          title="Facebook"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <a 
          href="https://instagram.com" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="flex items-center justify-center w-10 h-10 rounded-full bg-[#1F3D2B] text-white hover:bg-[#C47A2C] transition-all duration-200 transform hover:scale-[1.15] cursor-pointer shadow-sm"
          title="Instagram"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
          </svg>
        </a>
        <button 
          id="share-button"
          class="flex items-center justify-center w-10 h-10 rounded-full bg-[#1F3D2B] text-white hover:bg-[#C47A2C] transition-all duration-200 transform hover:scale-[1.15] cursor-pointer shadow-sm"
          title="Compartir"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 12v7a2 2 0 002 2h12a2 2 0 002-2v-7M16 6l-4-4-4 4m4-4v13"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Navigation Column -->
    <div class="space-y-4">
      <h5 class="font-bold text-on-surface dark:text-inverse-on-surface uppercase tracking-wider text-sm">Explorar</h5>
      <ul class="space-y-2 font-body-md text-body-md">
        <li><a class="text-on-surface-variant dark:text-surface-variant hover:text-secondary transition-colors" href={`${cleanBase}tours/`}>Tours y Experiencias</a></li>
        <li><a class="text-on-surface-variant dark:text-surface-variant hover:text-secondary transition-colors" href={`${cleanBase}tours/camaguey-laberintica/`}>Camagüey Laberíntica</a></li>
        <li><a class="text-on-surface-variant dark:text-surface-variant hover:text-secondary transition-colors" href={`${cleanBase}tours/flamencos-sabanas/`}>Flamencos y Sabanas</a></li>
        <li><a class="text-on-surface-variant dark:text-surface-variant hover:text-secondary transition-colors" href={`${cleanBase}tours/mesa-camagueyana/`}>Mesa Camagüeyana</a></li>
      </ul>
    </div>

    <!-- Categories / Info Column -->
    <div class="space-y-4">
      <h5 class="font-bold text-on-surface dark:text-inverse-on-surface uppercase tracking-wider text-sm">Destinos</h5>
      <ul class="space-y-2 font-body-md text-body-md">
        <li class="text-on-surface-variant dark:text-surface-variant">Sierra de Cubitas</li>
        <li class="text-on-surface-variant dark:text-surface-variant">Limones-Tuabaquey</li>
        <li class="text-on-surface-variant dark:text-surface-variant">Plaza de San Juan</li>
        <li class="text-on-surface-variant dark:text-surface-variant">Patios Coloniales</li>
      </ul>
    </div>
  </div>

  <!-- Copyright Bar -->
  <div class="border-t border-outline-variant/30 py-6 text-center">
    <p class="text-on-surface-variant dark:text-surface-variant text-[12px] font-body-md">
      © 2025 CartaCuba. Preservando el patrimonio de Camagüey.
    </p>
  </div>
</footer>

<script is:inline>
  document.getElementById('share-button')?.addEventListener('click', () => {
    if (navigator.share) {
      navigator.share({
        title: 'CartaCuba — Descubre Cuba desde dentro',
        text: 'Experiencias turísticas auténticas en Camagüey, Cuba',
        url: window.location.href
      }).catch(err => console.log('Error sharing:', err));
    } else {
      navigator.clipboard.writeText(window.location.href)
        .then(() => {
          let tooltip = document.getElementById('share-tooltip');
          if (!tooltip) {
            tooltip = document.createElement('div');
            tooltip.id = 'share-tooltip';
            tooltip.className = 'fixed bottom-4 left-1/2 -translate-x-1/2 bg-inverse-surface text-inverse-on-surface px-4 py-2 rounded-full text-xs font-bold shadow-lg z-50 transition-opacity duration-300 opacity-0';
            tooltip.innerText = '¡Enlace copiado!';
            document.body.appendChild(tooltip);
          }
          // Force layout reflow
          tooltip.getBoundingClientRect();
          tooltip.classList.remove('opacity-0');
          tooltip.classList.add('opacity-100');
          
          setTimeout(() => {
            tooltip.classList.remove('opacity-100');
            tooltip.classList.add('opacity-0');
          }, 2000);
        })
        .catch(err => console.error('Error copying text: ', err));
    }
  });
</script>
