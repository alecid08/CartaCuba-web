---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Nosotros y Contacto | CartaCuba" activePage="nosotros">
  <div class="grain-texture fixed inset-0 z-0 pointer-events-none opacity-40"></div>

  <!-- Hero Section -->
  <section class="relative py-20 overflow-hidden flex items-center justify-center text-center min-h-[320px] md:min-h-[420px]" style="background: linear-gradient(135deg, #1F3D2B 0%, #3E6B48 100%);">
    <div class="relative z-10 px-margin-mobile md:px-margin-desktop max-w-4xl mx-auto space-y-4 text-[#FFFFFF]">
      <span class="inline-block bg-white/10 border border-white/20 text-[#FFFFFF] px-4 py-1.5 rounded-full font-label-md text-sm uppercase tracking-wider">
        Quiénes Somos y Contacto
      </span>
      <h1 class="font-display-lg text-display-lg-mobile md:text-5xl lg:text-6xl font-bold leading-tight drop-shadow-md">
        Nuestra Filosofía y <span class="text-[#FFFFFF] italic font-normal">Compromiso</span>
      </h1>
      <p class="font-body-lg text-[#FFFFFF] max-w-2xl mx-auto text-sm md:text-base">
        Descubre quiénes estamos detrás de CartaCuba y cómo trabajamos codo con codo con las comunidades locales para ofrecerte una experiencia inolvidable.
      </p>
    </div>
  </section>

  <main class="relative z-10 bg-background">
    <!-- History & Philosophy Section -->
    <section class="py-24 bg-surface-container-low border-b border-outline-variant/20">
      <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
        <div class="grid md:grid-cols-2 gap-16 items-center">
          <div class="space-y-6">
            <span class="text-primary font-label-md uppercase tracking-wider block">Nuestra Historia</span>
            <h2 class="font-headline-md text-headline-md text-on-surface font-semibold">El Propósito de CartaCuba</h2>
            <p class="font-body-lg text-on-surface-variant">
              CartaCuba nació del deseo de proteger y dar a conocer la riqueza ecológica y cultural de Camagüey. Inspirados por el Cartacuba, un pequeño pero majestuoso pájaro endémico cubano que anida en el silencio de nuestros bosques, diseñamos viajes guiados que no dejan huellas ecológicas negativas, sino un impacto económico directo en la comunidad de artesanos y conservacionistas locales.
            </p>
            <p class="font-body-md text-on-surface-variant text-sm">
              Creemos firmemente en el ecoturismo ético y en el turismo de patrimonio vivo. No promovemos recorridos masivos; en su lugar, priorizamos pequeños grupos de aventureros dispuestos a escuchar los saberes del campo, a amasar la arcilla junto a maestros alfareros y a caminar con el mayor respeto por la biodiversidad.
            </p>
          </div>
          <div class="relative">
            <div class="absolute -top-10 -left-10 w-40 h-40 bg-primary/10 rounded-full blur-3xl"></div>
            <img 
              alt="Ecoturismo y Guías locales en Camagüey" 
              class="leaf-shape w-full h-[450px] object-cover border border-outline-variant/30 shadow-md"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuCQwIULpWJ17ul5O1lHNna3YCyoTqOcSpFNP6hAEr2R3LJZQh0wTv2e2W4dELlbm4L6cwIXQPJ70029GuW8QIgG6u4lSDvDIGN5k1yulQv01LD1Zq7j_yCmbrlTJwNXI44iZ7VJMm_K50md6EjmwJ8fqZUj2C8iSXe6ZCBZch1Ao9EfptJ5TeWuhkf1SvHss0q35zRjb5Sh6omjUBP-JRGL2t3JW91GHlBx4pTA3Kk32k3e_PhvumMRJ9rZH-BeAQcW5HLf8VrJKRXQCg"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Host Section -->
    <section class="py-24 bg-background border-b border-outline-variant/20">
      <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
        <div class="grid md:grid-cols-2 gap-16 items-center">
          <div class="relative order-2 md:order-1">
            <div class="absolute -top-10 -left-10 w-40 h-40 bg-primary/10 rounded-full blur-3xl"></div>
            <img 
              alt="Alejandro, anfitrión y fundador de CartaCuba" 
              class="leaf-shape w-full h-[450px] object-cover border border-outline-variant/30 shadow-md"
              src="/alejandro_host.png"
            />
          </div>
          <div class="space-y-6 order-1 md:order-2">
            <span class="text-primary font-label-md uppercase tracking-wider block">El Anfitrión</span>
            <h2 class="font-headline-md text-headline-md text-on-surface font-semibold">El Anfitrión</h2>
            <p class="font-body-lg text-on-surface-variant">
              CartaCuba nació de una convicción simple: Camagüey merece ser descubierta, no consumida. Soy Alejandro, camagüeyano de nacimiento y fundador de este proyecto. Crecí en las mismas calles laberínticas que hoy guío, aprendí las historias de los tinajones antes de aprender a leerlas en los libros, y con los años comprendí que el turismo convencional estaba convirtiendo una ciudad viva en una postal.
            </p>
            <p class="font-body-md text-on-surface-variant text-sm">
              CartaCuba no es una agencia. Es una forma de entender el viaje: cercana, honesta, adaptable a cada grupo y a cada momento. No tengo guiones fijos. Tengo historias reales, alianzas con artistas, cocineras, artesanos y naturalistas de la provincia que hacen de cada experiencia algo irrepetible.
            </p>
            <p class="font-body-md text-on-surface font-semibold text-sm">
              Si visitas Camagüey con nosotros, no serás un turista. Serás un descubridor.
            </p>
            <div class="pt-4">
              <a 
                href="https://wa.me/+5351383690?text=Hola%20Alejandro%2C%20me%20gustar%C3%ADa%20conocer%20m%C3%A1s%20sobre%20CartaCuba."
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-primary text-white hover:bg-primary-container px-6 py-3 rounded-full font-label-md transition-all shadow-sm"
              >
                <span>Conversa con Alejandro por WhatsApp</span>
                <span class="material-symbols-outlined text-lg">chat</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Us Grid -->
    <section class="py-24 bg-surface-container-low border-b border-outline-variant/20">
      <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <span class="text-primary font-label-md uppercase tracking-wider block mb-2">Turismo Sostenible</span>
          <h2 class="font-headline-md text-headline-md text-on-surface font-semibold">¿Por Qué Viajar con CartaCuba?</h2>
          <p class="font-body-lg text-on-surface-variant mt-2">Nuestros pilares fundamentales garantizan viajes de gran valor humano y mínimo impacto ambiental.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
          <!-- Pillar 1 -->
          <div class="bg-surface-container p-10 rounded-3xl border border-outline-variant/30 hover:shadow-md transition-shadow flex flex-col justify-between">
            <div class="space-y-6">
              <span class="material-symbols-outlined text-primary text-5xl" style="font-variation-settings: 'FILL' 1;">groups</span>
              <h3 class="font-headline-sm text-lg text-on-surface font-semibold">Grupos Pequeños y Cercanos</h3>
              <p class="font-body-md text-sm text-on-surface-variant">Limitamos nuestros grupos a un máximo de 6 personas. Esto garantiza una experiencia íntima y personalizada, acceso a espacios privados y una conexión real con cada viajero.</p>
            </div>
            <span class="text-primary font-label-md text-xs uppercase tracking-wider block mt-8 font-semibold">Inmersión Personalizada</span>
          </div>

          <!-- Pillar 2 -->
          <div class="bg-surface-container p-10 rounded-3xl border border-outline-variant/30 hover:shadow-md transition-shadow flex flex-col justify-between">
            <div class="space-y-6">
              <span class="material-symbols-outlined text-primary text-5xl" style="font-variation-settings: 'FILL' 1;">badge</span>
              <h3 class="font-headline-sm text-lg text-on-surface font-semibold">Guías 100% Locales</h3>
              <p class="font-body-md text-sm text-on-surface-variant">Nuestros guías son historiadores y naturalistas nacidos en Camagüey. Reciben una remuneración justa, promoviendo el empleo verde y garantizando saberes culturales auténticos.</p>
            </div>
            <span class="text-primary font-label-md text-xs uppercase tracking-wider block mt-8 font-semibold">Desarrollo Comunitario</span>
          </div>

          <!-- Pillar 3 -->
          <div class="bg-surface-container p-10 rounded-3xl border border-outline-variant/30 hover:shadow-md transition-shadow flex flex-col justify-between">
            <div class="space-y-6">
              <span class="material-symbols-outlined text-primary text-5xl" style="font-variation-settings: 'FILL' 1;">eco</span>
              <h3 class="font-headline-sm text-lg text-on-surface font-semibold">Compromiso Ecológico Directo</h3>
              <p class="font-body-md text-sm text-on-surface-variant">Destinamos un porcentaje de cada reserva a proyectos locales de conservación de aves en la Sierra del Chorrillo y a talleres de reforestación botánica nativa.</p>
            </div>
            <span class="text-primary font-label-md text-xs uppercase tracking-wider block mt-8 font-semibold">Retorno a la Tierra</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact & Map Section -->
    <section class="py-24 bg-background">
      <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
          
          <!-- Contact Info Column -->
          <div class="lg:col-span-4 space-y-8">
            <div>
              <span class="text-primary font-label-md uppercase tracking-wider block mb-2">Canales de Comunicación</span>
              <h2 class="font-headline-md text-headline-md text-on-surface font-semibold">Ponte en Contacto</h2>
              <p class="font-body-md text-on-surface-variant mt-2 text-sm">¿Tienes preguntas sobre un recorrido a medida o deseas detalles sobre el impacto ecológico? Estamos listos para asistirte.</p>
            </div>

            <!-- Contact detail cards -->
            <div class="space-y-4">
              <!-- Detail 1 -->
              <div class="flex items-center gap-4 bg-background p-4 rounded-2xl border border-outline-variant/30">
                <span class="material-symbols-outlined text-primary text-2xl">call</span>
                <div>
                  <span class="font-label-md text-xs text-on-surface-variant block">Teléfono / WhatsApp</span>
                  <a href="https://wa.me/+5351383690" class="font-body-md text-on-surface font-semibold hover:underline">+53 51383690</a>
                </div>
              </div>
              <!-- Detail 2 -->
              <div class="flex items-center gap-4 bg-background p-4 rounded-2xl border border-outline-variant/30">
                <span class="material-symbols-outlined text-primary text-2xl">mail</span>
                <div>
                  <span class="font-label-md text-xs text-on-surface-variant block">Correo Electrónico</span>
                  <a href="mailto:reservas@cartacuba.com" class="font-body-md text-on-surface font-semibold hover:underline">reservas@cartacuba.com</a>
                </div>
              </div>
              <!-- Detail 3 -->
              <div class="flex items-center gap-4 bg-background p-4 rounded-2xl border border-outline-variant/30">
                <span class="material-symbols-outlined text-primary text-2xl">location_on</span>
                <div>
                  <span class="font-label-md text-xs text-on-surface-variant block">Ubicación Principal</span>
                  <span class="font-body-md text-on-surface font-semibold">Centro Histórico, Camagüey, Cuba</span>
                </div>
              </div>
            </div>

            <!-- Stylized Map Mock -->
            <div class="relative rounded-3xl overflow-hidden shadow-lg border border-outline-variant/30 h-[220px] group">
              <img alt="Map of Camagüey" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500 opacity-60" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCDtK47MuTH0yyDrxrvb3MFUPiQm71qKapo30b6V6oXWOTlreS8lxHcAXWon_Ib955mJ6SuhFTsks0dlDAK2FQ-kM_NaL1grkQV31fEFeza4ivrTns-LslK8_GoLRlXmjl8NKm7dc-XPOKtMvvIz-0huZIHc3HQhXV2k3qPG39XhWV91gXXVuHcR9S9SkqMM9ERGDsP4ezmZb7EsNBFXv2zvi9O2fPqDXxzvhN2lT-udxrlIQv3gCs77sS5n_r-JFVccai0N0Y8hFk">
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="bg-primary text-white w-10 h-10 rounded-full flex items-center justify-center shadow-lg border-2 border-white animate-bounce">
                  <span class="material-symbols-outlined text-lg">location_on</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Contact Form Column -->
          <div class="lg:col-span-8 bg-background p-8 md:p-12 rounded-[2.5rem] border border-outline-variant/40 shadow-sm relative">
            
            <!-- Success Screen Overlay (Hidden initially) -->
            <div id="form-success-screen" class="hidden absolute inset-0 bg-background/95 rounded-[2.5rem] flex flex-col items-center justify-center text-center p-8 z-20 transition-all duration-300">
              <span class="material-symbols-outlined text-primary text-6xl mb-4 animate-bounce">check_circle</span>
              <h3 class="font-headline-md text-2xl text-on-surface font-semibold">¡Mensaje Enviado con Éxito!</h3>
              <p class="font-body-md text-on-surface-variant max-w-sm mt-2">
                Gracias por ponerte en contacto con CartaCuba. Uno de nuestros coordinadores locales te responderá al correo electrónico en menos de 24 horas.
              </p>
              <button 
                type="button" 
                id="reset-form-btn" 
                class="mt-8 px-6 py-3 bg-primary text-white rounded-full font-label-md text-sm hover:bg-primary-container transition-all"
              >
                Enviar Otro Mensaje
              </button>
            </div>

            <!-- Form Header -->
            <div class="mb-8">
              <h3 class="font-headline-sm text-2xl text-on-surface font-semibold">Formulario de Reserva & Consultas</h3>
              <p class="text-on-surface-variant font-body-md text-sm mt-1">Completa el formulario para enviarnos un correo, o envíanos un chat directo por WhatsApp.</p>
            </div>

            <form id="contact-form" class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Name -->
                <div class="space-y-2">
                  <label for="contact-name" class="font-label-md text-xs text-on-surface-variant uppercase tracking-wider block">Nombre Completo</label>
                  <input 
                    type="text" 
                    id="contact-name" 
                    required 
                    placeholder="Tu nombre" 
                    class="w-full bg-surface-container border border-outline-variant/50 rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary text-sm"
                  />
                </div>
                <!-- Email -->
                <div class="space-y-2">
                  <label for="contact-email" class="font-label-md text-xs text-on-surface-variant uppercase tracking-wider block">Correo Electrónico</label>
                  <input 
                    type="email" 
                    id="contact-email" 
                    required 
                    placeholder="correo@ejemplo.com" 
                    class="w-full bg-surface-container border border-outline-variant/50 rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary text-sm"
                  />
                </div>
              </div>

              <!-- Subject -->
              <div class="space-y-2">
                <label for="contact-subject" class="font-label-md text-xs text-on-surface-variant uppercase tracking-wider block">Asunto de Consulta</label>
                <select 
                  id="contact-subject" 
                  class="w-full bg-surface-container border border-outline-variant/50 rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary text-sm"
                >
                  <option value="consulta">Consulta General</option>
                  <option value="reserva">Reserva de Tour</option>
                  <option value="personalizado">Viaje Personalizado</option>
                  <option value="conservacion">Soporte a Proyectos de Conservación</option>
                </select>
              </div>

              <!-- Message -->
              <div class="space-y-2">
                <label for="contact-message" class="font-label-md text-xs text-on-surface-variant uppercase tracking-wider block">Tu Mensaje</label>
                <textarea 
                  id="contact-message" 
                  rows="5" 
                  required 
                  placeholder="Describe qué tipo de experiencia buscas o cuáles son tus dudas..." 
                  class="w-full bg-surface-container border border-outline-variant/50 rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary text-sm resize-none"
                ></textarea>
              </div>

              <!-- Action Buttons -->
              <div class="flex flex-col sm:flex-row gap-4 pt-4">
                <!-- Submit Web Form -->
                <button 
                  type="submit" 
                  id="submit-btn" 
                  class="flex-1 px-6 py-4 bg-primary text-white rounded-full font-label-md text-sm hover:bg-primary-container transition-all flex items-center justify-center gap-2 shadow-md active:scale-95"
                >
                  <span id="submit-btn-text">Enviar Mensaje por Web</span>
                  <span class="material-symbols-outlined text-lg">send</span>
                </button>
                
                <!-- Send to WhatsApp -->
                <button 
                  type="button" 
                  id="whatsapp-submit-btn" 
                  class="px-6 py-4 border border-[#25D366] text-[#25D366] hover:bg-[#25D366]/5 rounded-full font-label-md text-sm transition-all flex items-center justify-center gap-2 active:scale-95"
                >
                  <span>Chatear por WhatsApp</span>
                  <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.457L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.625 1.451 5.403.002 9.803-4.381 9.806-9.791.001-2.592-1.01-5.031-2.852-6.874a9.71 9.71 0 0 0-6.83-2.781c-5.41 0-9.81 4.384-9.813 9.795-.001 1.57.426 3.102 1.236 4.469l-1.015 3.704 3.828-1.004zM17.15 14.54c-.294-.147-1.74-.858-2.01-.957-.27-.099-.467-.147-.663.148-.196.294-.76.957-.93 1.152-.172.196-.344.22-.638.073-.293-.146-1.242-.457-2.366-1.458-.875-.78-1.465-1.744-1.637-2.038-.172-.294-.018-.453.128-.598.133-.131.294-.343.442-.515.147-.171.196-.293.294-.49.098-.195.049-.367-.025-.515-.074-.147-.663-1.597-.908-2.186-.239-.574-.482-.497-.663-.506-.172-.008-.368-.01-.565-.01-.196 0-.515.074-.784.368-.269.294-1.03 1.005-1.03 2.451 0 1.446 1.053 2.843 1.2 3.039.147.196 2.073 3.166 5.02 4.444.701.304 1.249.485 1.674.62.705.224 1.346.193 1.853.118.565-.084 1.74-.711 1.985-1.396.246-.686.246-1.274.172-1.397-.074-.122-.27-.196-.565-.343z"/>
                  </svg>
                </button>
              </div>
            </form>
          </div>

        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  const contactForm = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const submitBtnText = document.getElementById('submit-btn-text');
  const whatsappSubmitBtn = document.getElementById('whatsapp-submit-btn');
  const successScreen = document.getElementById('form-success-screen');
  const resetFormBtn = document.getElementById('reset-form-btn');

  // Submit via Web simulated form action
  contactForm.addEventListener('submit', (e) => {
    e.preventDefault();
    
    // Disable inputs and show loader
    submitBtn.disabled = true;
    submitBtnText.textContent = "Enviando mensaje...";
    submitBtn.classList.add('opacity-75', 'cursor-not-allowed');

    setTimeout(() => {
      // Show success screen
      successScreen.classList.replace('hidden', 'flex');
      
      // Reset button states
      submitBtn.disabled = false;
      submitBtnText.textContent = "Enviar Mensaje por Web";
      submitBtn.classList.remove('opacity-75', 'cursor-not-allowed');
    }, 1500);
  });

  // Reset form success screen
  resetFormBtn.addEventListener('click', () => {
    successScreen.classList.replace('flex', 'hidden');
    contactForm.reset();
  });

  // Submit via WhatsApp link generation
  whatsappSubmitBtn.addEventListener('click', () => {
    const name = document.getElementById('contact-name').value.trim();
    const email = document.getElementById('contact-email').value.trim();
    const subjectSelect = document.getElementById('contact-subject');
    const subject = subjectSelect.options[subjectSelect.selectedIndex].text;
    const message = document.getElementById('contact-message').value.trim();

    if (!name || !email || !message) {
      alert('Por favor, rellena los campos de Nombre, Correo y Mensaje para generar tu consulta de WhatsApp.');
      return;
    }

    // Message formulation
    const whatsappMessage = `Hola CartaCuba! Mi nombre es ${name} (${email}). Deseo realizar una consulta sobre: "${subject}".\n\nMensaje: ${message}`;
    
    // Redirect to WhatsApp URL
    const whatsappUrl = `https://wa.me/+5351383690?text=${encodeURIComponent(whatsappMessage)}`;
    window.open(whatsappUrl, '_blank');
  });
</script>
