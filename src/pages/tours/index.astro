---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { tours } from '../../data/tours.js';

const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith('/') ? base : `${base}/`;

// Find the featured/most popular tour (Avistamiento de Aves)
const featuredTour = tours.find(t => t.id === 'avistamiento-aves') || tours[0];
---

<BaseLayout title="Nuestros Tours | CartaCuba" activePage="tours">
  <!-- Top Banner / Hero -->
  <section class="relative pt-32 pb-24 bg-surface-container-high overflow-hidden">
    <div class="organic-grain absolute inset-0 pointer-events-none opacity-40"></div>
    <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto relative z-10 grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7 space-y-6">
        <span class="bg-primary/10 text-primary font-label-md px-4 py-1.5 rounded-full uppercase tracking-wider text-xs">Catálogo Oficial</span>
        <h1 class="font-display-lg text-display-lg-mobile md:text-5xl text-on-surface font-bold leading-tight">
          Explora Camagüey a Través de <br/>
          <span class="text-primary italic font-normal">Experiencias Reales</span>
        </h1>
        <p class="text-on-surface-variant font-body-lg max-w-xl">
          Diseñamos recorridos de bajo impacto ecológico y alto valor cultural. Viaja en grupos pequeños acompañados por guías locales y apoya directamente a la comunidad agramontina.
        </p>
      </div>
      
      <!-- Featured Tour CTA Banner -->
      <div class="lg:col-span-5 bg-white dark:bg-inverse-surface border border-outline-variant/30 rounded-3xl p-6 sm:p-8 shadow-md relative overflow-hidden group">
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-secondary/5 rounded-full group-hover:scale-110 transition-transform"></div>
        <div class="relative z-10 space-y-4">
          <div class="flex justify-between items-start">
            <span class="bg-[#e41e27] text-white text-[11px] font-label-md px-3 py-1 rounded-full uppercase tracking-wider">Más Vendido</span>
            <div class="text-right">
              <span class="text-xs text-on-surface-variant dark:text-surface-variant block uppercase">Precio especial</span>
              <span class="font-bold text-primary font-headline-sm text-lg">${featuredTour.price} USD</span>
            </div>
          </div>
          <h3 class="font-headline-sm text-[20px] text-on-surface dark:text-inverse-on-surface font-bold">
            {featuredTour.title}
          </h3>
          <p class="text-on-surface-variant dark:text-surface-variant font-body-md text-sm line-clamp-3">
            {featuredTour.shortDescription}
          </p>
          <div class="pt-2">
            <a 
              href={`${cleanBase}tours/${featuredTour.id}/`} 
              class="w-full bg-[#bb0017] hover:bg-[#a00012] text-white text-center py-3 px-6 rounded-full font-label-md text-label-md flex items-center justify-center gap-2 transition-all hover:scale-[1.02] active:scale-[0.98]"
            >
              <span>Reservar Tour Destacado</span>
              <span class="material-symbols-outlined text-[18px]">explore</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <main class="py-24 bg-background">
    <!-- Tours Catalog Grid -->
    <section class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto space-y-16">
      <div class="text-center max-w-2xl mx-auto space-y-4">
        <h2 class="font-headline-md text-headline-md text-on-surface font-bold">Todos Nuestros Recorridos</h2>
        <p class="text-on-surface-variant font-body-md">
          Encuentra la inmersión perfecta en la naturaleza de la biosfera cubana o la rica historia colonial agramontina.
        </p>
      </div>

      <!-- Large cards grid (Static, all cards visible) -->
      <div class="space-y-12">
        {tours.map((tour, idx) => (
          <div class="tour-card border border-outline-variant/20 rounded-3xl overflow-hidden shadow-sm hover:shadow-md transition-all grid md:grid-cols-12 gap-0 group relative">
            <!-- Link covering the entire card -->
            <a href={`${cleanBase}tours/${tour.id}/`} class="absolute inset-0 z-10" aria-label={`Ver detalles de ${tour.title}`}></a>

            <!-- 1. Imagen (izquierda en desktop ~42% o md:col-span-5, arriba en mobile - alternada en index impar) -->
            <div class={`md:col-span-5 relative h-64 md:h-auto overflow-hidden bg-surface-container ${idx % 2 === 1 ? 'md:order-last' : ''}`}>
              <img 
                alt={tour.title} 
                class="w-full h-full object-cover group-hover:scale-[1.05] transition-transform duration-300 ease-in-out" 
                src={tour.image}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent md:hidden"></div>
              <span class="absolute top-4 left-4 bg-primary text-white text-xs font-label-md px-3 py-1 rounded-full uppercase tracking-wider flex items-center gap-1 shadow-sm z-20">
                <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">{tour.badgeIcon}</span>
                {tour.category}
              </span>
            </div>

            <!-- Content Area (derecha en desktop o md:col-span-7) -->
            <div class="md:col-span-7 p-6 sm:p-10 flex flex-col justify-between space-y-4 relative z-20">
              <div class="space-y-3">
                <!-- 2. Nombre del tour — bold, grande, color #1F3D2B -->
                <h3 class="font-headline-sm text-2xl font-bold text-[#1F3D2B] dark:text-[#E8D8B7]">
                  {tour.title}
                </h3>

                <!-- 3. Duración — color #C47A2C, ligeramente más grande -->
                <div class="flex items-center gap-1.5 text-[#C47A2C] font-label-md text-base font-semibold uppercase tracking-wider">
                  <span class="material-symbols-outlined text-[18px]">schedule</span>
                  <span>{tour.duration}</span>
                </div>

                <!-- 4. Descripción breve — max 2 líneas -->
                <p class="text-on-surface-variant dark:text-surface-variant font-body-md text-sm line-clamp-2 leading-relaxed">
                  {tour.shortDescription}
                </p>
              </div>

              <!-- 5. Precio & 6. Botón CTA al fondo -->
              <div class="pt-4 border-t border-outline-variant/20 flex flex-col sm:flex-row sm:items-center justify-between gap-4 mt-auto">
                <div>
                  <span class="text-on-surface-variant dark:text-surface-variant text-sm font-medium">
                    Desde <strong class="text-[#1F3D2B] dark:text-[#E8D8B7] text-lg font-bold">${tour.price} USD</strong> / persona
                  </span>
                </div>
                
                <div class="bg-[#1F3D2B]/10 text-[#1F3D2B] group-hover:bg-[#1F3D2B] group-hover:text-white px-8 py-3 rounded-full font-label-md text-sm font-bold flex items-center justify-center gap-2 transition-all duration-300">
                  <span>Ver Detalles</span>
                  <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .tour-card {
    background-color: #E8D8B7;
    transition: background-color 0.3s ease, box-shadow 0.3s ease;
  }
  .tour-card:hover {
    background-color: #D4E8D4 !important;
  }
</style>
